<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
{{template "admin_head_assets" .}}
<style>
{{template "admin_common_styles" .}}
.page-intro{margin-top:12px}
.sort-btn{background:none;border:0;color:inherit;padding:0;cursor:pointer;font:inherit;transition:color .18s ease}
.sort-btn:hover{color:var(--text-strong)}
.row-form{margin-top:20px}
.cell-form{margin:0}
.cell-form button{transition:background-color .18s ease,border-color .18s ease,color .18s ease}
</style>
</head>
<body><div class="page">
{{template "admin_nav" .}}
<h1>Models</h1>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
<section class="panel">
<div class="panel-toolbar">
<div>
<h2 class="panel-title">Model Routing</h2>
{{if .IsAdmin}}
<p class="panel-copy page-intro">Map each public model alias to a provider connection and upstream model ID.</p>
{{else}}
<p class="panel-copy page-intro">Models currently available through your managed gateway access.</p>
{{end}}
</div>
{{if .IsAdmin}}<div class="panel-actions"><button type="button" onclick="openDialog('modelCreateDialog')">New Model</button></div>{{end}}
</div>
</section>
<div class="table-wrap"><table id="models-table">
  <thead>
    <tr>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',0)">Public Model</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',1)">Provider</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',2)">Upstream Model</button></th>
      {{if .IsAdmin}}<th></th>{{end}}
    </tr>
  </thead>
  <tbody>
    {{range .Models}}
    <tr>
      <td>{{.PublicName}}</td>
      <td>{{.Provider}}</td>
      <td>{{.UpstreamName}}</td>
      {{if $.IsAdmin}}
      <td>
        <form method="post" action="/admin/models/delete" class="cell-form" onsubmit="return confirmDeleteModel()">
          <input type="hidden" name="public_name" value="{{.PublicName}}">
          <button type="submit">Delete</button>
        </form>
      </td>
      {{end}}
    </tr>
    {{else}}
    <tr><td colspan="{{if .IsAdmin}}4{{else}}3{{end}}" class="muted">No models configured</td></tr>
    {{end}}
  </tbody>
</table></div>
{{if .IsAdmin}}
<dialog id="modelCreateDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">New Model</h2>
        <p class="modal-copy">Create a public model alias and route it to one provider target.</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('modelCreateDialog')" aria-label="Close">×</button>
    </div>
    <form method="post" action="/admin/models" class="modal-form">
      <div class="modal-grid">
        <div class="field-group">
          <label for="model-public-name">Public Name</label>
          <input id="model-public-name" name="public_name" placeholder="Public model alias">
        </div>
        <div class="field-group">
          <label for="model-provider">Provider</label>
          <select id="model-provider" name="provider">{{range .Providers}}<option value="{{.}}">{{.}}</option>{{end}}</select>
        </div>
      </div>
      <div class="field-group">
        <label for="model-upstream-name">Upstream Name</label>
        <input id="model-upstream-name" name="upstream_name" placeholder="Upstream model ID">
      </div>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('modelCreateDialog')">Cancel</button>
        <button type="submit">Save</button>
      </div>
    </form>
  </div>
</dialog>
{{end}}
<script>
function openDialog(id){
  const dialog = document.getElementById(id);
  if(dialog && typeof dialog.showModal === 'function'){dialog.showModal();}
}

function closeDialog(id){
  const dialog = document.getElementById(id);
  if(dialog){dialog.close();}
}

function sortTable(tableId, col){
  const table = document.getElementById(tableId);
  if(!table || !table.tBodies || table.tBodies.length === 0){return;}
  const tbody = table.tBodies[0];
  const rows = Array.from(tbody.rows);
  if(rows.length === 0){return;}
  const nextAsc = table.dataset.sortCol !== String(col) ? true : table.dataset.sortAsc !== "true";
  rows.sort((a, b) => {
    const av = (a.cells[col]?.textContent || "").trim();
    const bv = (b.cells[col]?.textContent || "").trim();
    return nextAsc ? av.localeCompare(bv) : bv.localeCompare(av);
  });
  for(const row of rows){tbody.appendChild(row);}
  table.dataset.sortCol = String(col);
  table.dataset.sortAsc = nextAsc ? "true" : "false";
}

function confirmDeleteModel(){
  return window.confirm("Delete this model?");
}

document.getElementById('modelCreateDialog')?.addEventListener('click', function(e){
  const rect = this.getBoundingClientRect();
  const inside = e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
  if(!inside){this.close();}
});
</script>
</div></body>
</html>
