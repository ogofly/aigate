<!doctype html>
<html><head><meta charset="utf-8"><title>{{.Title}}</title>
<style>body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;max-width:1280px;margin:32px auto;padding:0 16px;color:#fffffe;background:#16161a}nav a{margin-right:16px;color:#fffffe;text-decoration:none}table{width:100%;border-collapse:collapse;margin-top:24px;background:rgba(255,255,255,.03)}th,td{padding:10px;border-bottom:1px solid #72757e;text-align:left}input,select{padding:10px;border:1px solid #72757e;border-radius:8px;margin-right:8px;background:#fffffe;color:#010101}button{padding:8px 12px;border:0;background:#7f5af0;color:#fffffe;border-radius:8px;cursor:pointer;font-weight:600}.muted{color:#94a1b2}.flash{padding:10px 12px;background:#72757e;border-radius:8px;margin-top:16px;color:#fffffe}</style>
</head><body>{{template "admin_nav" .}}<h1>Models</h1>{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}{{if .IsAdmin}}<form method="post" action="/admin/models" style="margin-top:20px"><input name="public_name" placeholder="public name"><select name="provider">{{range .Providers}}<option value="{{.}}">{{.}}</option>{{end}}</select><input name="upstream_name" placeholder="upstream name"><button type="submit">Save</button></form>{{else}}<div class="muted" style="margin-top:12px">OpenAI compatible models list for current user.</div>{{end}}<table><thead><tr><th>Public</th><th>Provider</th><th>Upstream</th>{{if .IsAdmin}}<th></th>{{end}}</tr></thead><tbody>{{range .Models}}<tr><td>{{.PublicName}}</td><td>{{.Provider}}</td><td>{{.UpstreamName}}</td>{{if $.IsAdmin}}<td><form method="post" action="/admin/models/delete"><input type="hidden" name="public_name" value="{{.PublicName}}"><button type="submit">Delete</button></form></td>{{end}}</tr>{{else}}<tr><td colspan="{{if .IsAdmin}}4{{else}}3{{end}}" class="muted">No models</td></tr>{{end}}</tbody></table></body></html>
