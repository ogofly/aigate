<!doctype html>
<html lang="{{.Lang}}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
{{template "admin_head_assets" .}}
{{template "admin_theme_init" .}}
<style>
{{template "admin_common_styles" .}}
.page-intro{margin-top:12px}
.sort-btn{background:none;border:0;color:inherit;padding:0;cursor:pointer;font:inherit;transition:color .18s ease}
.sort-btn:hover{color:var(--text-strong)}
.row-form{margin-top:20px}
.cell-form{margin:0}
.cell-form button{transition:background-color .18s ease,border-color .18s ease,color .18s ease}
.routing-summary{display:flex;flex-wrap:wrap;gap:12px;margin-top:8px}
.routing-item{min-width:160px}
.routing-rules{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
.model-create-fields[hidden]{display:none}
.bulk-model-list{min-height:160px;resize:vertical}
.batch-preview{display:grid;gap:8px;margin-top:2px;padding:10px;border:1px solid var(--line);border-radius:6px;background:rgba(210,214,220,.02)}
.batch-preview[hidden]{display:none}
.batch-preview-list{display:grid;gap:4px;max-height:150px;overflow:auto}
.batch-preview-row{display:grid;grid-template-columns:42px minmax(0,1fr);gap:8px;align-items:start;font-size:12px}
.batch-preview-row span{overflow-wrap:anywhere}
</style>
</head>
<body><div class="page">
{{template "admin_nav" .}}
<h1>{{.T "Models"}}</h1>
{{if .Flash}}<div class="flash">{{.T .Flash}}</div>{{end}}
<section class="panel">
<div class="panel-toolbar">
<div>
  <h2 class="panel-title">{{.T "Routing Settings"}}</h2>
  <p class="panel-copy">{{.T "Selection strategy and global failover apply to every public model alias."}}</p>
</div>
{{if .IsAdmin}}<div class="panel-actions"><button type="button" onclick="openDialog('routingDialog')">{{.T "Edit Settings"}}</button></div>{{end}}
</div>
<div class="routing-summary">
<div class="routing-item"><div class="muted">{{.T "Selection"}}</div><div><span class="badge info">{{.Routing.Selection}}</span></div></div>
<div class="routing-item"><div class="muted">{{.T "Failover"}}</div><div>{{if .Routing.FailoverEnabled}}<span class="badge ok">{{.T "Enabled"}}</span>{{else}}<span class="badge off">{{.T "Disabled"}}</span>{{end}}</div></div>
<div class="routing-item"><div class="muted">{{.T "Max Attempts"}}</div><div>{{.Routing.FailoverMaxAttempts}}</div></div>
</div>
<div class="routing-rules" aria-label="Routing rules">
  <span class="badge">{{.T "priority: lower number first"}}</span>
  <span class="badge">{{.T "weight/random: sticky by session/body"}}</span>
  <span class="badge">{{.T "failover: eligible failures only"}}</span>
</div>
</section>
<section class="panel">
<div class="panel-toolbar">
<div>
<h2 class="panel-title">{{.T "Model Routing"}}</h2>
{{if .IsAdmin}}
<p class="panel-copy page-intro">{{.T "Map each public model alias to a provider connection and upstream model ID."}}</p>
{{else}}
<p class="panel-copy page-intro">{{.T "Models currently available through your managed gateway access."}}</p>
{{end}}
</div>
{{if .IsAdmin}}<div class="panel-actions"><button type="button" onclick="openDialog('modelCreateDialog')">{{.T "New Model"}}</button></div>{{end}}
</div>
</section>
<div class="table-wrap"><table id="models-table">
  <thead>
    <tr>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',0,'text')">{{.T "Public Model"}}</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',1,'text')">{{.T "Provider"}}</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',2,'text')">{{.T "Upstream Model"}}</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',3,'num')">{{.T "Priority"}}</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',4,'num')">{{.T "Weight"}}</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('models-table',5,'text')">{{.T "Enabled"}}</button></th>
      {{if .IsAdmin}}<th></th>{{end}}
    </tr>
  </thead>
  <tbody>
    {{range .Models}}
    <tr>
      <td>{{.PublicName}}</td>
      <td>{{.Provider}}</td>
      <td>{{.UpstreamName}}</td>
      <td>{{.Priority}}</td>
      <td>{{.Weight}}</td>
      <td>{{if .Enabled}}<span class="badge ok">{{$.T "Enabled"}}</span>{{else}}<span class="badge off">{{$.T "Disabled"}}</span>{{end}}</td>
      {{if $.IsAdmin}}
      <td>
        <button type="button" data-route-id="{{.ID}}" onclick="openModelEditDialog(this, '{{.PublicName}}', '{{.Provider}}', '{{.UpstreamName}}', '{{.Priority}}', '{{.Weight}}', {{if .Enabled}}true{{else}}false{{end}})">{{$.T "Edit"}}</button>
        <button type="button" class="danger" data-route-id="{{.ID}}" data-public-name="{{.PublicName}}" onclick="submitModelDelete(this)">{{$.T "Delete"}}</button>
      </td>
      {{end}}
    </tr>
    {{else}}
    <tr><td colspan="{{if .IsAdmin}}7{{else}}6{{end}}" class="muted">{{.T "No models configured"}}</td></tr>
    {{end}}
  </tbody>
</table></div>
{{if .IsAdmin}}
<dialog id="routingDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">{{.T "Edit Routing Settings"}}</h2>
        <p class="modal-copy">{{.T "Choose the default route ordering and failover behavior."}}</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('routingDialog')" aria-label="{{.T "Close"}}">×</button>
    </div>
    <form onsubmit="submitRoutingUpdate(this);return false" class="modal-form">
      <div class="modal-grid">
        <div class="field-group">
          <label for="routing-selection">{{.T "Selection"}}</label>
          <select id="routing-selection" name="selection">
            <option value="priority" {{if eq .Routing.Selection "priority"}}selected{{end}}>priority</option>
            <option value="weight" {{if eq .Routing.Selection "weight"}}selected{{end}}>weight</option>
            <option value="random" {{if eq .Routing.Selection "random"}}selected{{end}}>random</option>
          </select>
        </div>
        <div class="field-group">
          <label for="routing-max-attempts">{{.T "Failover Attempts"}}</label>
          <input id="routing-max-attempts" name="failover_max_attempts" value="{{.Routing.FailoverMaxAttempts}}">
        </div>
      </div>
      <label class="checkline"><input type="checkbox" name="failover_enabled" value="true" {{if .Routing.FailoverEnabled}}checked{{end}}>{{.T "Failover Enabled"}}</label>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('routingDialog')">{{.T "Cancel"}}</button>
        <button type="submit">{{.T "Save"}}</button>
      </div>
    </form>
  </div>
</dialog>
<dialog id="modelCreateDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">{{.T "New Model"}}</h2>
        <p class="modal-copy">{{.T "Create a public model alias and route it to one provider target."}}</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('modelCreateDialog')" aria-label="{{.T "Close"}}">×</button>
    </div>
    <form onsubmit="submitModelCreate(this);return false" class="modal-form">
      <div class="field-group">
        <label for="model-create-mode">{{.T "Mode"}}</label>
        <select id="model-create-mode" name="create_mode" onchange="toggleModelCreateMode(this)">
          <option value="single">single</option>
          <option value="batch">batch</option>
        </select>
      </div>
      <div id="model-create-single-fields" class="model-create-fields">
      <div class="modal-grid">
        <div class="field-group">
          <label for="model-public-name">{{.T "Public Name"}}</label>
          <input id="model-public-name" name="public_name" placeholder="{{.T "Public model alias"}}" required>
        </div>
        <div class="field-group">
          <label for="model-provider">{{.T "Provider"}}</label>
          <select id="model-provider" name="provider" required>{{range .Providers}}<option value="{{.}}">{{.}}</option>{{end}}</select>
        </div>
      </div>
      <div class="field-group">
        <label for="model-upstream-name">{{.T "Upstream Name"}}</label>
        <input id="model-upstream-name" name="upstream_name" placeholder="{{.T "Upstream model ID"}}" required>
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="model-priority">{{.T "Priority"}}</label>
          <input id="model-priority" name="priority" value="0">
          <p class="form-hint">{{.T "Lower number wins."}}</p>
        </div>
        <div class="field-group">
          <label for="model-weight">{{.T "Weight"}}</label>
          <input id="model-weight" name="weight" value="1">
          <p class="form-hint">{{.T "Used only when selection is weight."}}</p>
        </div>
      </div>
      <label class="checkline"><input type="checkbox" name="enabled" checked>{{.T "Enabled"}}</label>
      </div>
      <div id="model-create-batch-fields" class="model-create-fields" hidden>
      <div class="field-group">
        <label for="batch-model-provider">{{.T "Provider"}}</label>
        <select id="batch-model-provider" name="batch_provider">{{range .Providers}}<option value="{{.}}">{{.}}</option>{{end}}</select>
      </div>
      <div class="field-group">
        <label for="batch-model-lines">{{.T "Models"}}</label>
        <textarea id="batch-model-lines" class="bulk-model-list" name="batch_models" placeholder="gpt-4o&#10;gpt-4o-mini&#10;public-name => upstream-model&#10;public-name, upstream-model"></textarea>
        <p class="form-hint">{{.T "One model per line. A single value uses the same public and upstream name."}}</p>
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="batch-model-priority">{{.T "Priority"}}</label>
          <input id="batch-model-priority" name="batch_priority" value="0">
          <p class="form-hint">{{.T "Lower number wins."}}</p>
        </div>
        <div class="field-group">
          <label for="batch-model-weight">{{.T "Weight"}}</label>
          <input id="batch-model-weight" name="batch_weight" value="1">
          <p class="form-hint">{{.T "Used only when selection is weight."}}</p>
        </div>
      </div>
      <label class="checkline"><input type="checkbox" name="batch_enabled" checked>{{.T "Enabled"}}</label>
      <div id="batch-model-preview" class="batch-preview" hidden></div>
      </div>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('modelCreateDialog')">{{.T "Cancel"}}</button>
        <button type="button" class="ghost" id="batch-preview-action" onclick="previewBatchModels(this.form)" hidden>{{.T "Preview"}}</button>
        <button type="submit">{{.T "Save"}}</button>
      </div>
    </form>
  </div>
</dialog>
<dialog id="modelEditDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">{{.T "Edit Model"}}</h2>
        <p class="modal-copy">{{.T "Update the provider or upstream model for this alias."}}</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('modelEditDialog')" aria-label="{{.T "Close"}}">×</button>
    </div>
    <form onsubmit="submitModelUpdate(this);return false" class="modal-form">
      <input type="hidden" id="edit-model-route-id" name="model_id">
      <div class="modal-grid">
        <div class="field-group">
          <label for="edit-model-public-name">{{.T "Public Name"}}</label>
          <input id="edit-model-public-name" name="public_name" placeholder="{{.T "Public model alias"}}" required>
        </div>
        <div class="field-group">
          <label for="edit-model-provider">{{.T "Provider"}}</label>
          <select id="edit-model-provider" name="provider" required>{{range .Providers}}<option value="{{.}}">{{.}}</option>{{end}}</select>
        </div>
      </div>
      <div class="field-group">
        <label for="edit-model-upstream-name">{{.T "Upstream Name"}}</label>
        <input id="edit-model-upstream-name" name="upstream_name" placeholder="{{.T "Upstream model ID"}}" required>
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="edit-model-priority">{{.T "Priority"}}</label>
          <input id="edit-model-priority" name="priority">
          <p class="form-hint">{{.T "Lower number wins."}}</p>
        </div>
        <div class="field-group">
          <label for="edit-model-weight">{{.T "Weight"}}</label>
          <input id="edit-model-weight" name="weight">
          <p class="form-hint">{{.T "Used only when selection is weight."}}</p>
        </div>
      </div>
      <label class="checkline"><input type="checkbox" id="edit-model-enabled" name="enabled" value="true"> {{.T "Enabled"}}</label>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('modelEditDialog')">{{.T "Cancel"}}</button>
        <button type="submit">{{.T "Save"}}</button>
      </div>
    </form>
  </div>
</dialog>
{{end}}
{{template "admin_dialog_helpers" .}}
<script>
function sortTable(tableId, col, kind){
  const table = document.getElementById(tableId);
  if(!table || !table.tBodies || table.tBodies.length === 0){return;}
  const tbody = table.tBodies[0];
  const rows = Array.from(tbody.rows);
  if(rows.length === 0){return;}
  const nextAsc = table.dataset.sortCol !== String(col) ? true : table.dataset.sortAsc !== "true";
  rows.sort((a, b) => {
    const av = (a.cells[col]?.textContent || "").trim();
    const bv = (b.cells[col]?.textContent || "").trim();
    if(kind === 'num'){
      const an = Number.parseInt(av, 10) || 0;
      const bn = Number.parseInt(bv, 10) || 0;
      return nextAsc ? an - bn : bn - an;
    }
    return nextAsc ? av.localeCompare(bv) : bv.localeCompare(av);
  });
  for(const row of rows){tbody.appendChild(row);}
  table.dataset.sortCol = String(col);
  table.dataset.sortAsc = nextAsc ? "true" : "false";
}

function confirmDeleteModel(name){
  return confirm({{toJSON (.T "Delete model: ")}} + name + '?');
}

function toggleModelCreateMode(select){
  const form = select.closest('form');
  const batch = select.value === 'batch';
  const singleFields = form.querySelector('#model-create-single-fields');
  const batchFields = form.querySelector('#model-create-batch-fields');
  if(singleFields){singleFields.hidden = batch;}
  if(batchFields){batchFields.hidden = !batch;}
  form.querySelectorAll('#model-create-single-fields [required]').forEach(input => { input.required = !batch; });
  const previewButton = form.querySelector('#batch-preview-action');
  if(previewButton){previewButton.hidden = !batch;}
  if(!batch){clearBatchPreview(form);}
}

async function submitModelCreate(form){
  if((form.querySelector('[name=create_mode]')?.value || 'single') === 'batch'){
    await submitModelBatchCreate(form);
    return;
  }
  const data = {
    public_name: form.querySelector('[name=public_name]').value,
    provider: form.querySelector('[name=provider]').value,
    upstream_name: form.querySelector('[name=upstream_name]').value,
    priority: parseInt(form.querySelector('[name=priority]').value) || 0,
    weight: parseInt(form.querySelector('[name=weight]').value) || 1,
    enabled: form.querySelector('[name=enabled]').checked,
  };
  const result = await apiCall('POST', '/api/admin/models', data);
  if (result && result.ok) {
    closeDialog('modelCreateDialog');
    reloadAfterToast({{toJSON (.T "Model saved")}});
  }
}

function parseBatchModelLines(value){
  const routes = [];
  const errors = [];
  const lines = value.split(/\r?\n/);
  for(let i = 0; i < lines.length; i++){
    const line = lines[i].trim();
    if(!line || line.startsWith('#')){continue;}
    let publicName = line;
    let upstreamName = line;
    const separators = ['=>', ',', '\t'];
    for(const separator of separators){
      const idx = line.indexOf(separator);
      if(idx > -1){
        publicName = line.slice(0, idx).trim();
        upstreamName = line.slice(idx + separator.length).trim();
        break;
      }
    }
    if(!publicName || !upstreamName){
      errors.push({line:i + 1, text:line, message:{{toJSON (.T "missing public or upstream name")}});
      continue;
    }
    routes.push({line:i + 1, public_name: publicName, upstream_name: upstreamName});
  }
  return {routes: routes, errors: errors};
}

function batchPreviewBox(form){
  return form.querySelector('#batch-model-preview');
}

function clearBatchPreview(form){
  const preview = batchPreviewBox(form);
  if(preview){
    preview.hidden = true;
    preview.innerHTML = '';
    preview.dataset.confirmed = '';
    preview.dataset.signature = '';
  }
}

function batchSignature(form){
  return [
    form.querySelector('[name=batch_provider]').value,
    form.querySelector('[name=batch_models]').value,
    form.querySelector('[name=batch_priority]').value,
    form.querySelector('[name=batch_weight]').value,
    form.querySelector('[name=batch_enabled]').checked ? '1' : '0',
  ].join('\n---\n');
}

function renderBatchPreview(form, parsed){
  const preview = batchPreviewBox(form);
  if(!preview){return;}
  const provider = form.querySelector('[name=batch_provider]').value;
  const priority = parseInt(form.querySelector('[name=batch_priority]').value) || 0;
  const weight = parseInt(form.querySelector('[name=batch_weight]').value) || 1;
  const enabled = form.querySelector('[name=batch_enabled]').checked;
  const rows = parsed.routes.slice(0, 12).map(function(route){
    return '<div class="batch-preview-row"><strong>#' + route.line + '</strong><span>' + escapeHTML(route.public_name) + ' / ' + escapeHTML(provider) + ' / ' + escapeHTML(route.upstream_name) + '</span></div>';
  }).join('');
  const errors = parsed.errors.map(function(err){
    return '<div class="batch-preview-row"><strong>#' + err.line + '</strong><span class="muted">' + escapeHTML(err.message) + ': ' + escapeHTML(err.text) + '</span></div>';
  }).join('');
  preview.innerHTML = [
    '<div><span class="badge info">' + parsed.routes.length + ' ' + {{toJSON (.T "routes")}} + '</span> <span class="badge">' + escapeHTML(provider) + '</span> <span class="badge">' + {{toJSON (.T "priority ")}} + priority + '</span> <span class="badge">' + {{toJSON (.T "weight ")}} + weight + '</span> ' + (enabled ? '<span class="badge ok">' + {{toJSON (.T "Enabled")}} + '</span>' : '<span class="badge off">' + {{toJSON (.T "Disabled")}} + '</span>') + '</div>',
    rows ? '<div class="batch-preview-list">' + rows + (parsed.routes.length > 12 ? '<div class="muted">+' + (parsed.routes.length - 12) + ' ' + {{toJSON (.T "more")}} + '</div>' : '') + '</div>' : '',
    errors ? '<div class="batch-preview-list">' + errors + '</div>' : '',
    parsed.errors.length ? '<p class="form-hint">' + {{toJSON (.T "Fix the invalid lines before saving.")}} + '</p>' : '<p class="form-hint">' + {{toJSON (.T "Preview confirmed. Press Save to add these routes.")}} + '</p>',
  ].join('');
  preview.hidden = false;
  preview.dataset.confirmed = parsed.errors.length ? '' : 'true';
  preview.dataset.signature = parsed.errors.length ? '' : batchSignature(form);
}

function escapeHTML(value){
  return String(value).replace(/[&<>"']/g, function(ch){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch];
  });
}

function previewBatchModels(form){
  const parsed = parseBatchModelLines(form.querySelector('[name=batch_models]').value || '');
  if(parsed.routes.length === 0 && parsed.errors.length === 0){
    showAjaxError({{toJSON (.T "Add at least one model.")}}, {{toJSON (.T "The batch model list is empty.")}});
    return null;
  }
  renderBatchPreview(form, parsed);
  return parsed;
}

async function submitModelBatchCreate(form){
  const preview = batchPreviewBox(form);
  if(!preview || preview.dataset.confirmed !== 'true' || preview.dataset.signature !== batchSignature(form)){
    previewBatchModels(form);
    showToast({{toJSON (.T "Review preview, then Save")}});
    return;
  }
  const parsed = previewBatchModels(form);
  if(!parsed || parsed.errors.length > 0){
    return;
  }
  const provider = form.querySelector('[name=batch_provider]').value;
  const priority = parseInt(form.querySelector('[name=batch_priority]').value) || 0;
  const weight = parseInt(form.querySelector('[name=batch_weight]').value) || 1;
  const enabled = form.querySelector('[name=batch_enabled]').checked;
  let created = 0;
  for(const route of parsed.routes){
    const result = await apiCall('POST', '/api/admin/models', {
      public_name: route.public_name,
      provider: provider,
      upstream_name: route.upstream_name,
      priority: priority,
      weight: weight,
      enabled: enabled,
    });
    if(!result){
      showAjaxError({{toJSON (.T "Batch stopped after ")}} + created + {{toJSON (.T " routes.")}}, {{toJSON (.T "Failed at line ")}} + route.line + {{toJSON (.T ": ")}} + route.public_name);
      return;
    }
    created++;
  }
  closeDialog('modelCreateDialog');
  reloadAfterToast({{toJSON (.T "Models added: ")}} + created);
}

async function submitModelDelete(btn){
  const routeId = btn.dataset.routeId || "";
  const publicName = btn.dataset.publicName || routeId;
  if(!confirm({{toJSON (.T "Delete model: ")}} + publicName + '?')) return;
  const result = await apiCall('DELETE', '/api/admin/models/' + encodeURIComponent(routeId));
  if (result && result.ok) {
    btn.closest('tr').remove();
    showToast({{toJSON (.T "Model deleted")}});
  }
}

function openModelEditDialog(button, publicName, provider, upstreamName, priority, weight, enabled){
  const form = document.querySelector('#modelEditDialog form');
  form.querySelector('[name=model_id]').value = button.dataset.routeId || "";
  form.querySelector('[name=public_name]').value = publicName;
  form.querySelector('[name=provider]').value = provider;
  form.querySelector('[name=upstream_name]').value = upstreamName;
  form.querySelector('[name=priority]').value = priority;
  form.querySelector('[name=weight]').value = weight;
  form.querySelector('[name=enabled]').checked = enabled;
  openDialog('modelEditDialog');
}

async function submitModelUpdate(form){
  const modelId = form.querySelector('[name=model_id]').value;
  const data = {
    public_name: form.querySelector('[name=public_name]').value,
    provider: form.querySelector('[name=provider]').value,
    upstream_name: form.querySelector('[name=upstream_name]').value,
    priority: parseInt(form.querySelector('[name=priority]').value) || 0,
    weight: parseInt(form.querySelector('[name=weight]').value) || 1,
    enabled: form.querySelector('[name=enabled]').checked,
  };
  const result = await apiCall('PUT', '/api/admin/models/' + encodeURIComponent(modelId), data);
  if (result && result.ok) {
    closeDialog('modelEditDialog');
    reloadAfterToast({{toJSON (.T "Model saved")}});
  }
}

async function submitRoutingUpdate(form){
  const data = {
    selection: form.querySelector('[name=selection]').value,
    failover_enabled: form.querySelector('[name=failover_enabled]').checked,
    failover_max_attempts: parseInt(form.querySelector('[name=failover_max_attempts]').value) || 2,
  };
  const result = await apiCall('PUT', '/api/admin/routing', data);
  if (result && result.ok) {
    closeDialog('routingDialog');
    reloadAfterToast({{toJSON (.T "Routing saved")}});
  }
}

document.querySelectorAll('#modelCreateDialog [name=batch_models], #modelCreateDialog [name=batch_provider], #modelCreateDialog [name=batch_priority], #modelCreateDialog [name=batch_weight], #modelCreateDialog [name=batch_enabled]').forEach(function(el){
  el.addEventListener('input', function(){ clearBatchPreview(el.closest('form')); });
  el.addEventListener('change', function(){ clearBatchPreview(el.closest('form')); });
});
</script>
