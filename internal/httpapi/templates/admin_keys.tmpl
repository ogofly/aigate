<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>{{.Title}}</title>
<style>
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;max-width:1280px;margin:32px auto;padding:0 16px;color:#fffffe;background:#16161a}
nav a{margin-right:16px;color:#fffffe;text-decoration:none}
table{width:100%;border-collapse:collapse;margin-top:24px;background:rgba(255,255,255,.03)}
th,td{padding:10px;border-bottom:1px solid #72757e;text-align:left}
input{padding:10px;border:1px solid #72757e;border-radius:8px;margin-right:8px;min-width:120px;background:#fffffe;color:#010101}
label{margin-right:12px}
button{padding:8px 12px;border:0;background:#7f5af0;color:#fffffe;border-radius:8px;cursor:pointer;font-weight:600}
.muted{color:#94a1b2}
.flash{padding:10px 12px;background:#72757e;border-radius:8px;margin-top:16px;color:#fffffe}
.key-cell{display:flex;align-items:center;gap:8px}
.key-text{font-family:ui-monospace,SFMono-Regular,monospace;cursor:pointer;color:#7f5af0}
.ghost{background:#f3f3f3;color:#111}
.key-gen{display:inline-flex;align-items:stretch;margin-right:8px}
#new-key-input{margin-right:0;border-radius:8px 0 0 8px}
.gen-btn{border-radius:0 8px 8px 0}
</style>
</head>
<body>
{{template "admin_nav" .}}
<h1>Keys</h1>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
<div class="muted" style="margin-top:8px">OpenAI compatible: base URL <span class="key-text" style="cursor:text">{{.APIBase}}/v1</span>, use <span class="key-text" style="cursor:text">Authorization: Bearer &lt;api_key&gt;</span>.</div>
<div class="muted" style="margin-top:4px">Anthropic: base URL <span class="key-text" style="cursor:text">{{.APIBase}}/anthropic</span>, use <span class="key-text" style="cursor:text">Authorization: Bearer &lt;api_key&gt;</span>.</div>

<form method="post" action="/admin/keys" style="margin-top:20px">
  <span class="key-gen">
    <input id="new-key-input" name="key" placeholder="api key">
    <button type="button" class="ghost gen-btn" onclick="generateKey()">Generate</button>
  </span>
  <input name="name" placeholder="name">
  {{if .IsAdmin}}<input name="owner" placeholder="owner">{{end}}
  <input name="purpose" placeholder="purpose">
  <button type="submit">Save</button>
</form>

<table>
  <thead>
    <tr>
      <th>Name</th>
      {{if .IsAdmin}}<th>Owner</th>{{end}}
      <th>Purpose</th>
      <th>Key</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{range .Keys}}
    <tr>
      <td>{{.Name}}</td>
      {{if $.IsAdmin}}<td>{{.Owner}}</td>{{end}}
      <td>{{.Purpose}}</td>
      <td>
        <div class="key-cell">
          <span class="key-text" data-key="{{.Key}}" onclick="toggleKeyText(this)">****</span>
          <button type="button" class="ghost" onclick="copyKey(this)">Copy</button>
        </div>
      </td>
      <td>
        <form method="post" action="/admin/keys/delete" onsubmit="return confirmDeleteKey()">
          <input type="hidden" name="key" value="{{.Key}}">
          <button type="submit">Delete</button>
        </form>
      </td>
    </tr>
    {{else}}
    <tr><td colspan="{{if .IsAdmin}}5{{else}}4{{end}}" class="muted">No keys</td></tr>
    {{end}}
  </tbody>
</table>

<script>
function toggleKeyText(text){
  const hidden = text.textContent === '****';
  text.textContent = hidden ? text.dataset.key : '****';
}

async function copyKey(button){
  const text = button.parentNode.querySelector('.key-text');
  const value = text.dataset.key;
  try{
    await copyWithFallback(value);
    button.textContent='Copied';
    setTimeout(()=>{button.textContent='Copy';},1200);
  }catch(_e){
    button.textContent='Copy failed';
    setTimeout(()=>{button.textContent='Copy';},1200);
  }
}

async function copyWithFallback(value){
  if (navigator.clipboard && window.isSecureContext) {
    await navigator.clipboard.writeText(value);
    return;
  }
  const textArea = document.createElement("textarea");
  textArea.value = value;
  textArea.setAttribute("readonly", "");
  textArea.style.position = "fixed";
  textArea.style.left = "-9999px";
  document.body.appendChild(textArea);
  textArea.select();
  const ok = document.execCommand("copy");
  document.body.removeChild(textArea);
  if (!ok) {
    throw new Error("copy failed");
  }
}

function randomSuffix(length){
  const alphabet = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
  const bytes = new Uint8Array(length);
  if (window.crypto && window.crypto.getRandomValues) {
    window.crypto.getRandomValues(bytes);
  } else {
    for (let i = 0; i < length; i++) {
      bytes[i] = Math.floor(Math.random() * 256);
    }
  }
  let out = "";
  for (let i = 0; i < length; i++) {
    out += alphabet[bytes[i] % alphabet.length];
  }
  return out;
}

function generateKey(){
  const input = document.getElementById("new-key-input");
  if (!input) {
    return;
  }
  input.value = "sk-" + randomSuffix(32);
  input.focus();
  input.select();
}

function confirmDeleteKey(){
  return window.confirm("Delete this API key?");
}
</script>
</body>
</html>
