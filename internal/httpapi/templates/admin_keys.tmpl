<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
{{template "admin_head_assets" .}}
{{template "admin_theme_init" .}}
<style>
{{template "admin_common_styles" .}}
.key-cell{display:flex;align-items:center;gap:8px}
.key-text{font-family:ui-monospace,SFMono-Regular,monospace;cursor:pointer;color:var(--text)}
.page-copy{margin-top:8px}
.keys-form{margin-top:20px}
.key-cell{flex-wrap:wrap}
.key-text{overflow-wrap:anywhere}
.key-text:hover{color:var(--text)}
.copy-text{cursor:pointer;text-decoration:underline;text-decoration-color:rgba(210,214,220,.18);text-underline-offset:3px}
.copy-text:hover{color:var(--text-strong);text-decoration-color:rgba(139,92,246,.38)}
.copy-feedback{margin-left:6px;color:var(--muted);font-size:12px}
.key-create-form{display:flex;flex-direction:column;gap:12px}
.key-create-grid{gap:10px;align-items:start}
.key-span{grid-column:1 / -1}
.key-gen{display:flex;align-items:stretch;min-width:0}
#new-key-input,.gen-btn{height:42px}
#new-key-input{flex:1 1 auto;min-width:0;margin-right:0;border-radius:8px 0 0 8px}
.gen-btn{flex:0 0 auto;padding:0 14px;border-radius:0 8px 8px 0;white-space:nowrap}
.route-list{max-height:240px;overflow:auto;border:1px solid var(--line);border-radius:8px;padding:8px;display:grid;gap:8px}
.route-access-block[hidden]{display:none}
.route-group{display:grid;gap:3px}
.route-group-title{display:flex;justify-content:space-between;gap:8px;font-size:12px;font-weight:700;color:var(--text-strong);line-height:1.35;padding:2px 4px;overflow-wrap:anywhere}
.route-selected-count{flex:0 0 auto;color:var(--muted);font-weight:600}
.route-group-items{display:grid;gap:2px}
.route-option{display:grid;grid-template-columns:18px minmax(0,1fr);gap:8px;align-items:start;min-height:32px;padding:6px;border-radius:6px}
.route-option:hover{background:rgba(210,214,220,.025)}
.route-option input{margin:2px 0 0}
.route-option span{overflow-wrap:anywhere;line-height:1.35}
.route-provider{color:var(--text)}
</style>
</head>
<body><div class="page">
{{template "admin_nav" .}}
<h1>Keys</h1>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
<section class="panel">
<div class="panel-toolbar">
  <div>
    <h2 class="panel-title">Managed Keys</h2>
    <p class="panel-copy">Create gateway keys for teammates, services, and test clients without exposing upstream provider secrets.</p>
  </div>
  <div class="panel-actions"><button type="button" onclick="openDialog('keyCreateDialog')">New Key</button></div>
</div>
<div class="muted page-copy">OpenAI-compatible base URL: <span class="key-text copy-text" data-copy="{{.APIBase}}/v1" title="点击可复制" tabindex="0" role="button" onclick="copyInline(this)" onkeydown="copyInlineKeydown(event, this)">{{.APIBase}}/v1</span><span class="copy-feedback" aria-live="polite"></span> with <span class="key-text">Authorization: Bearer &lt;api_key&gt;</span>.</div>
<div class="muted" style="margin-top:4px">Anthropic-compatible base URL: <span class="key-text copy-text" data-copy="{{.APIBase}}/anthropic" title="点击可复制" tabindex="0" role="button" onclick="copyInline(this)" onkeydown="copyInlineKeydown(event, this)">{{.APIBase}}/anthropic</span><span class="copy-feedback" aria-live="polite"></span> with <span class="key-text">Authorization: Bearer &lt;api_key&gt;</span>.</div>
</section>

<div class="table-wrap"><table>
  <thead>
    <tr>
      <th>Name</th>
      {{if .IsAdmin}}<th>User</th>{{end}}
      <th>Purpose</th>
      <th>Model Access</th>
      <th>Key</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{range .Keys}}
    <tr>
      <td>{{.Name}}</td>
      {{if $.IsAdmin}}<td>{{.Owner}}</td>{{end}}
      <td>{{.Purpose}}</td>
      <td>{{if eq .ModelAccess "selected"}}<span class="badge info">Selected · {{len .ModelRouteIDs}} routes</span>{{else}}<span class="badge ok">All</span>{{end}}</td>
      <td>
        <div class="key-cell">
          <span class="key-text" data-key="{{.Key}}" onclick="toggleKeyText(this)">****</span>
          <button type="button" class="ghost" onclick="copyKey(this)">Copy</button>
        </div>
      </td>
      <td>
        <button type="button" data-model-access="{{.ModelAccess}}" data-route-ids="{{range .ModelRouteIDs}}{{.}},{{end}}" onclick="openKeyEditDialog(this, '{{.Name}}', '{{.Owner}}', '{{.Purpose}}', '{{.Key}}')">Edit</button>
        <button type="button" class="danger" onclick="submitKeyDelete(this, '{{.Name}}', '{{.Purpose}}', '{{.Key}}')">Delete</button>
      </td>
    </tr>
    {{else}}
    <tr><td colspan="{{if .IsAdmin}}6{{else}}5{{end}}" class="muted">No keys configured</td></tr>
    {{end}}
  </tbody>
</table></div>
<dialog id="keyCreateDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">New Key</h2>
        <p class="modal-copy">Create a managed key and add optional user and usage context.</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('keyCreateDialog')" aria-label="Close">×</button>
    </div>
    <form onsubmit="submitKeyCreate(this);return false" class="modal-form key-create-form">
      <div class="modal-grid key-create-grid">
        <div class="field-group key-span">
          <label for="new-key-input">API Key</label>
          <div class="key-gen">
            <input id="new-key-input" name="key" placeholder="Managed API key">
            <button type="button" class="ghost gen-btn" onclick="generateKey()">Generate</button>
          </div>
        </div>
        <div class="field-group">
          <label for="key-name">Name</label>
          <input id="key-name" name="name" placeholder="Display name">
        </div>
        {{if .IsAdmin}}
        <div class="field-group">
          <label for="key-owner">User</label>
          <input id="key-owner" name="owner" placeholder="User name">
        </div>
        {{end}}
        <div class="field-group key-span">
          <label for="key-purpose">Purpose</label>
          <input id="key-purpose" name="purpose" placeholder="Usage context">
        </div>
        <div class="field-group key-span">
          <label for="key-model-access">Model Access</label>
          <select id="key-model-access" name="model_access" onchange="toggleRouteList(this)">
            <option value="all">all</option>
            <option value="selected">selected</option>
          </select>
          <p class="form-hint">All can use every enabled route. Selected only allows checked routes. Disabled providers/routes are never usable.</p>
        </div>
        <div class="field-group key-span route-access-block" hidden>
          <label>Routes</label>
          <div class="route-list">
            {{range .ModelRouteGroups}}
            <div class="route-group">
              <div class="route-group-title"><span>{{.PublicName}}</span><span class="route-selected-count">0 selected</span></div>
              <div class="route-group-items">
                {{range .Routes}}
                <label class="route-option"><input type="checkbox" name="model_route_ids" value="{{.ID}}"><span><span class="route-provider">{{.Provider}}</span>{{if ne .UpstreamName .PublicName}} <span class="muted">· upstream: {{.UpstreamName}}</span>{{end}}{{if not .Enabled}} <span class="badge off">Disabled</span>{{end}}</span></label>
                {{end}}
              </div>
            </div>
            {{else}}<div class="muted">No routes configured</div>{{end}}
          </div>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('keyCreateDialog')">Cancel</button>
        <button type="submit">Save</button>
      </div>
    </form>
  </div>
</dialog>

<dialog id="keyEditDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">Edit Key</h2>
        <p class="modal-copy">Update the name, user, or purpose for this managed key.</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('keyEditDialog')" aria-label="Close">×</button>
    </div>
    <form onsubmit="submitKeyUpdate(this);return false" class="modal-form key-create-form">
      <input type="hidden" id="edit-key-value" name="key">
      <div class="modal-grid key-create-grid">
        <div class="field-group">
          <label for="edit-key-name">Name</label>
          <input id="edit-key-name" name="name" placeholder="Display name">
        </div>
        {{if .IsAdmin}}
        <div class="field-group">
          <label for="edit-key-owner">User</label>
          <input id="edit-key-owner" name="owner" placeholder="User name">
        </div>
        {{end}}
        <div class="field-group key-span">
          <label for="edit-key-purpose">Purpose</label>
          <input id="edit-key-purpose" name="purpose" placeholder="Usage context">
        </div>
        <div class="field-group key-span">
          <label for="edit-key-model-access">Model Access</label>
          <select id="edit-key-model-access" name="model_access" onchange="toggleRouteList(this)">
            <option value="all">all</option>
            <option value="selected">selected</option>
          </select>
          <p class="form-hint">All can use every enabled route. Selected only allows checked routes. Disabled providers/routes are never usable.</p>
        </div>
        <div class="field-group key-span route-access-block" hidden>
          <label>Routes</label>
          <div class="route-list">
            {{range .ModelRouteGroups}}
            <div class="route-group">
              <div class="route-group-title"><span>{{.PublicName}}</span><span class="route-selected-count">0 selected</span></div>
              <div class="route-group-items">
                {{range .Routes}}
                <label class="route-option"><input type="checkbox" name="model_route_ids" value="{{.ID}}"><span><span class="route-provider">{{.Provider}}</span>{{if ne .UpstreamName .PublicName}} <span class="muted">· upstream: {{.UpstreamName}}</span>{{end}}{{if not .Enabled}} <span class="badge off">Disabled</span>{{end}}</span></label>
                {{end}}
              </div>
            </div>
            {{else}}<div class="muted">No routes configured</div>{{end}}
          </div>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('keyEditDialog')">Cancel</button>
        <button type="submit">Save</button>
      </div>
    </form>
  </div>
</dialog>

{{template "admin_api_helpers" .}}
<script>
function openDialog(id){
  const dialog = document.getElementById(id);
  if(dialog && typeof dialog.showModal === 'function'){dialog.showModal();}
}

function closeDialog(id){
  const dialog = document.getElementById(id);
  if(dialog){dialog.close();}
}

function toggleKeyText(text){
  const hidden = text.textContent === '****';
  text.textContent = hidden ? text.dataset.key : '****';
}

async function copyKey(button){
  const text = button.parentNode.querySelector('.key-text');
  const value = text.dataset.key;
  try{
    await copyWithFallback(value);
    button.textContent='Copied';
    setTimeout(()=>{button.textContent='Copy';},1200);
  }catch(_e){
    button.textContent='Copy failed';
    setTimeout(()=>{button.textContent='Copy';},1200);
  }
}

async function copyInline(el){
  const feedback = el.nextElementSibling;
  try{
    await copyWithFallback(el.dataset.copy || el.textContent || "");
    if(feedback){feedback.textContent='Copied';}
    setTimeout(()=>{if(feedback){feedback.textContent='';}},1200);
  }catch(_e){
    if(feedback){feedback.textContent='Copy failed';}
    setTimeout(()=>{if(feedback){feedback.textContent='';}},1200);
  }
}

function copyInlineKeydown(event, el){
  if(event.key === "Enter" || event.key === " "){
    event.preventDefault();
    copyInline(el);
  }
}

async function copyWithFallback(value){
  if (navigator.clipboard && window.isSecureContext) {
    await navigator.clipboard.writeText(value);
    return;
  }
  const textArea = document.createElement("textarea");
  textArea.value = value;
  textArea.setAttribute("readonly", "");
  textArea.style.position = "fixed";
  textArea.style.left = "-9999px";
  document.body.appendChild(textArea);
  textArea.select();
  const ok = document.execCommand("copy");
  document.body.removeChild(textArea);
  if (!ok) {
    throw new Error("copy failed");
  }
}

function randomSuffix(length){
  const alphabet = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
  const bytes = new Uint8Array(length);
  if (window.crypto && window.crypto.getRandomValues) {
    window.crypto.getRandomValues(bytes);
  } else {
    for (let i = 0; i < length; i++) {
      bytes[i] = Math.floor(Math.random() * 256);
    }
  }
  let out = "";
  for (let i = 0; i < length; i++) {
    out += alphabet[bytes[i] % alphabet.length];
  }
  return out;
}

function generateKey(){
  const input = document.getElementById("new-key-input");
  if (!input) {
    return;
  }
  input.value = "sk-" + randomSuffix(32);
  input.focus();
  input.select();
}

function confirmDeleteKey(name, purpose){
  return confirm('Delete key: ' + name + (purpose ? ' (' + purpose + ')' : '') + '?');
}

function toggleRouteList(select){
  const block = select.closest('form')?.querySelector('.route-access-block');
  if(block){block.hidden = select.value !== 'selected';}
  updateRouteSelectionCounts(select.closest('form'));
}

function updateRouteSelectionCounts(form){
  if(!form){return;}
  form.querySelectorAll('.route-group').forEach(group => {
    const count = group.querySelectorAll('[name=model_route_ids]:checked').length;
    const label = group.querySelector('.route-selected-count');
    if(label){label.textContent = count + ' selected';}
  });
}

function selectedRouteIDs(form){
  const access = form.querySelector('[name=model_access]')?.value || 'all';
  if(access !== 'selected'){return [];}
  return Array.from(form.querySelectorAll('[name=model_route_ids]:checked')).map(input => input.value);
}

async function submitKeyCreate(form){
  const data = {
    key: form.querySelector('[name=key]').value,
    name: form.querySelector('[name=name]').value,
    purpose: form.querySelector('[name=purpose]').value,
    model_access: form.querySelector('[name=model_access]').value,
    model_route_ids: selectedRouteIDs(form),
  };
  const ownerField = form.querySelector('[name=owner]');
  if (ownerField) data.owner = ownerField.value;
  const result = await apiCall('POST', '/api/admin/keys', data);
  if (result && result.ok) {
    closeDialog('keyCreateDialog');
    reloadAfterToast('Key saved');
  }
}

async function submitKeyDelete(btn, name, purpose, key){
  if(!confirm('Delete key: ' + name + (purpose ? ' (' + purpose + ')' : '') + '?')) return;
  const result = await apiCall('DELETE', '/api/admin/keys/' + encodeURIComponent(key));
  if (result && result.ok) {
    btn.closest('tr').remove();
    showToast('Key deleted');
  }
}

function openKeyEditDialog(button, name, owner, purpose, key){
  const form = document.querySelector('#keyEditDialog form');
  form.querySelector('[name=key]').value = key;
  form.querySelector('[name=name]').value = name;
  const ownerField = form.querySelector('[name=owner]');
  if (ownerField) ownerField.value = owner;
  form.querySelector('[name=purpose]').value = purpose;
  const access = button.dataset.modelAccess || 'all';
  const routeIds = new Set((button.dataset.routeIds || '').split(',').filter(Boolean));
  form.querySelector('[name=model_access]').value = access === 'selected' ? 'selected' : 'all';
  form.querySelectorAll('[name=model_route_ids]').forEach(input => { input.checked = routeIds.has(input.value); });
  toggleRouteList(form.querySelector('[name=model_access]'));
  updateRouteSelectionCounts(form);
  openDialog('keyEditDialog');
}

async function submitKeyUpdate(form){
  const key = form.querySelector('[name=key]').value;
  const data = {
    name: form.querySelector('[name=name]').value,
    purpose: form.querySelector('[name=purpose]').value,
    model_access: form.querySelector('[name=model_access]').value,
    model_route_ids: selectedRouteIDs(form),
  };
  const ownerField = form.querySelector('[name=owner]');
  if (ownerField) data.owner = ownerField.value;
  const result = await apiCall('PUT', '/api/admin/keys/' + encodeURIComponent(key), data);
  if (result && result.ok) {
    closeDialog('keyEditDialog');
    reloadAfterToast('Key saved');
  }
}

document.querySelectorAll('[name=model_route_ids]').forEach(input => {
  input.addEventListener('change', function(){ updateRouteSelectionCounts(input.closest('form')); });
});

document.getElementById('keyCreateDialog')?.addEventListener('click', function(e){
  const rect = this.getBoundingClientRect();
  const inside = e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
  if(!inside){this.close();}
});
</script>
</div>{{template "admin_theme_toggle" .}}</body>
</html>
