<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
<style>
{{template "admin_common_styles" .}}
.key-cell{display:flex;align-items:center;gap:8px}
.key-text{font-family:ui-monospace,SFMono-Regular,monospace;cursor:pointer;color:var(--accent)}
.page-copy{margin-top:8px}
.keys-form{margin-top:20px}
.key-cell{flex-wrap:wrap}
.key-text{overflow-wrap:anywhere}
.key-create-form{display:flex;flex-direction:column;gap:12px}
.key-create-grid{gap:10px;align-items:start}
.key-span{grid-column:1 / -1}
.key-gen{display:flex;align-items:stretch;min-width:0}
#new-key-input,.gen-btn{height:42px}
#new-key-input{flex:1 1 auto;min-width:0;margin-right:0;border-radius:10px 0 0 10px}
.gen-btn{flex:0 0 auto;padding:0 14px;border-radius:0 10px 10px 0;white-space:nowrap}
</style>
</head>
<body><div class="page">
{{template "admin_nav" .}}
<h1>Keys</h1>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
<section class="panel">
<div class="panel-toolbar">
  <div>
    <h2 class="panel-title">Key Management</h2>
    <p class="panel-copy">Issue managed API keys and hand teammates an exact base URL without exposing upstream secrets.</p>
  </div>
  <div class="panel-actions"><button type="button" onclick="openDialog('keyCreateDialog')">Create Key</button></div>
</div>
<div class="muted page-copy">OpenAI compatible: base URL <span class="key-text" style="cursor:text">{{.APIBase}}/v1</span>, use <span class="key-text" style="cursor:text">Authorization: Bearer &lt;api_key&gt;</span>.</div>
<div class="muted" style="margin-top:4px">Anthropic: base URL <span class="key-text" style="cursor:text">{{.APIBase}}/anthropic</span>, use <span class="key-text" style="cursor:text">Authorization: Bearer &lt;api_key&gt;</span>.</div>
</section>

<div class="table-wrap"><table>
  <thead>
    <tr>
      <th>Name</th>
      {{if .IsAdmin}}<th>Owner</th>{{end}}
      <th>Purpose</th>
      <th>Key</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{range .Keys}}
    <tr>
      <td>{{.Name}}</td>
      {{if $.IsAdmin}}<td>{{.Owner}}</td>{{end}}
      <td>{{.Purpose}}</td>
      <td>
        <div class="key-cell">
          <span class="key-text" data-key="{{.Key}}" onclick="toggleKeyText(this)">****</span>
          <button type="button" class="ghost" onclick="copyKey(this)">Copy</button>
        </div>
      </td>
      <td>
        <form method="post" action="/admin/keys/delete" onsubmit="return confirmDeleteKey()">
          <input type="hidden" name="key" value="{{.Key}}">
          <button type="submit">Delete</button>
        </form>
      </td>
    </tr>
    {{else}}
    <tr><td colspan="{{if .IsAdmin}}5{{else}}4{{end}}" class="muted">No keys</td></tr>
    {{end}}
  </tbody>
</table></div>
<dialog id="keyCreateDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">Create Key</h2>
        <p class="modal-copy">Generate a managed key and optionally attach owner and purpose metadata.</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('keyCreateDialog')" aria-label="Close">×</button>
    </div>
    <form method="post" action="/admin/keys" class="modal-form key-create-form">
      <div class="modal-grid key-create-grid">
        <div class="field-group key-span">
          <label for="new-key-input">API Key</label>
          <div class="key-gen">
            <input id="new-key-input" name="key" placeholder="api key">
            <button type="button" class="ghost gen-btn" onclick="generateKey()">Generate</button>
          </div>
        </div>
        <div class="field-group">
          <label for="key-name">Name</label>
          <input id="key-name" name="name" placeholder="name">
        </div>
        {{if .IsAdmin}}
        <div class="field-group">
          <label for="key-owner">Owner</label>
          <input id="key-owner" name="owner" placeholder="owner">
        </div>
        {{end}}
        <div class="field-group key-span">
          <label for="key-purpose">Purpose</label>
          <input id="key-purpose" name="purpose" placeholder="purpose">
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('keyCreateDialog')">Cancel</button>
        <button type="submit">Save</button>
      </div>
    </form>
  </div>
</dialog>

<script>
function openDialog(id){
  const dialog = document.getElementById(id);
  if(dialog && typeof dialog.showModal === 'function'){dialog.showModal();}
}

function closeDialog(id){
  const dialog = document.getElementById(id);
  if(dialog){dialog.close();}
}

function toggleKeyText(text){
  const hidden = text.textContent === '****';
  text.textContent = hidden ? text.dataset.key : '****';
}

async function copyKey(button){
  const text = button.parentNode.querySelector('.key-text');
  const value = text.dataset.key;
  try{
    await copyWithFallback(value);
    button.textContent='Copied';
    setTimeout(()=>{button.textContent='Copy';},1200);
  }catch(_e){
    button.textContent='Copy failed';
    setTimeout(()=>{button.textContent='Copy';},1200);
  }
}

async function copyWithFallback(value){
  if (navigator.clipboard && window.isSecureContext) {
    await navigator.clipboard.writeText(value);
    return;
  }
  const textArea = document.createElement("textarea");
  textArea.value = value;
  textArea.setAttribute("readonly", "");
  textArea.style.position = "fixed";
  textArea.style.left = "-9999px";
  document.body.appendChild(textArea);
  textArea.select();
  const ok = document.execCommand("copy");
  document.body.removeChild(textArea);
  if (!ok) {
    throw new Error("copy failed");
  }
}

function randomSuffix(length){
  const alphabet = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
  const bytes = new Uint8Array(length);
  if (window.crypto && window.crypto.getRandomValues) {
    window.crypto.getRandomValues(bytes);
  } else {
    for (let i = 0; i < length; i++) {
      bytes[i] = Math.floor(Math.random() * 256);
    }
  }
  let out = "";
  for (let i = 0; i < length; i++) {
    out += alphabet[bytes[i] % alphabet.length];
  }
  return out;
}

function generateKey(){
  const input = document.getElementById("new-key-input");
  if (!input) {
    return;
  }
  input.value = "sk-" + randomSuffix(32);
  input.focus();
  input.select();
}

function confirmDeleteKey(){
  return window.confirm("Delete this API key?");
}

document.getElementById('keyCreateDialog')?.addEventListener('click', function(e){
  const rect = this.getBoundingClientRect();
  const inside = e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
  if(!inside){this.close();}
});
</script>
</div></body>
</html>
