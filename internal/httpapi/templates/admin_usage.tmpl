<!doctype html>
<html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{.Title}}</title>{{template "admin_head_assets" .}}
{{template "admin_theme_init" .}}
<style>
{{template "admin_common_styles" .}}
.page-intro{margin:0 0 16px}
.tabs{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px;padding-bottom:2px;font-size:13px}
.tab{padding:6px 12px;border:1px solid var(--line);color:var(--muted);cursor:pointer;text-decoration:none;border-radius:4px;background:rgba(210,214,220,.022);transition:background-color .18s ease,border-color .18s ease,color .18s ease,box-shadow .18s ease}
.tab:hover{background:rgba(210,214,220,.032);color:var(--text)}
.tab.active{background:rgba(210,214,220,.04);color:var(--text-strong);border-color:rgba(139,92,246,.26);box-shadow:inset 0 0 0 1px rgba(139,92,246,.1)}
.filters{display:grid;grid-template-columns:repeat(3,minmax(0,1fr)) auto;gap:10px;align-items:end;margin-top:12px}
.filters label{display:flex;flex-direction:column;gap:6px;font-size:13px;min-width:0}
.filter-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
a.clear-filters{color:var(--muted);text-decoration:none;font-size:13px}
#trendChart{width:100%;height:400px;margin-top:20px}
.trend-controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:12px;font-size:13px}
.trend-controls button{padding:6px 12px;font-size:13px;border:1px solid var(--line);background:rgba(210,214,220,.022);color:var(--muted);border-radius:4px;cursor:pointer;transition:background-color .18s ease,border-color .18s ease,color .18s ease,box-shadow .18s ease}
.trend-controls button:hover{background:rgba(210,214,220,.032);color:var(--text)}
.trend-controls button.active{background:rgba(210,214,220,.04);color:var(--text-strong);border-color:rgba(139,92,246,.26);box-shadow:inset 0 0 0 1px rgba(139,92,246,.1)}
.pie-chart{width:100%;height:300px;margin:16px 0}
.pie-controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:12px;font-size:13px}
.pie-controls button{padding:6px 12px;font-size:13px;border:1px solid var(--line);background:rgba(210,214,220,.022);color:var(--muted);border-radius:4px;cursor:pointer;transition:background-color .18s ease,border-color .18s ease,color .18s ease,box-shadow .18s ease}
.pie-controls button:hover{background:rgba(210,214,220,.032);color:var(--text)}
.pie-controls button.active{background:rgba(210,214,220,.04);color:var(--text-strong);border-color:rgba(139,92,246,.26);box-shadow:inset 0 0 0 1px rgba(139,92,246,.1)}
.no-data{text-align:center;padding:40px;color:var(--muted);font-size:16px}
@media (max-width:720px){
.filters{grid-template-columns:1fr}
.tabs{flex-wrap:nowrap;overflow-x:auto}
.tab{white-space:nowrap;flex:0 0 auto}
#trendChart{height:300px}
.pie-chart{height:240px}
}
</style>
</head><body><div class="page">
{{template "admin_nav" .}}
<h1>Usage</h1>
<section class="panel">
<h2 class="panel-title">Usage Analytics</h2>
<p class="panel-copy page-intro">Filter traffic by date range and model. Tables remain scrollable on smaller screens.</p>
<form method="get" action="/admin/usage/view" class="filters">
  <input type="hidden" name="view" value="{{.View}}">
  <label>Start Date <input type="date" name="start" value="{{.FilterStart}}"></label>
  <label>End Date <input type="date" name="end" value="{{.FilterEnd}}"></label>
  <label>Model <select name="model"><option value="">All</option>{{range .UsageModels}}<option value="{{.}}" {{if eq . $.FilterModel}}selected{{end}}>{{.}}</option>{{end}}</select></label>
  <div class="filter-actions">
    <button type="submit">Filter</button>
    {{if or .FilterStart .FilterEnd .FilterModel}}<a class="clear-filters" href="/admin/usage/view?view={{.View}}">Clear Filters</a>{{end}}
  </div>
</form>
{{define "tabFilters"}}{{if .FilterStart}}&start={{.FilterStart}}{{end}}{{if .FilterEnd}}&end={{.FilterEnd}}{{end}}{{if .FilterModel}}&model={{.FilterModel}}{{end}}{{if .PieMetric}}&pieMetric={{.PieMetric}}{{end}}{{end}}
<div class="tabs">
  <a class="tab{{if eq .View "trend"}} active{{end}}" href="/admin/usage/view?view=trend{{template "tabFilters" .}}">Trend</a>
  <a class="tab{{if eq .View "by_key"}} active{{end}}" href="/admin/usage/view?view=by_key{{template "tabFilters" .}}">By Key</a>
  <a class="tab{{if eq .View "by_model"}} active{{end}}" href="/admin/usage/view?view=by_model{{template "tabFilters" .}}">By Model</a>
</div>
</section>

{{if eq .View "trend"}}
<div id="trendControls" class="trend-controls">
  <span>Granularity:</span>
  <button type="button" class="gb-btn{{if ne .GroupBy "day"}} active{{end}}" data-group="hour">Hour</button>
  <button type="button" class="gb-btn{{if eq .GroupBy "day"}} active{{end}}" data-group="day">Day</button>
</div>
<div id="trendChart"></div>
<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
<script>
var trendGb = '{{if .GroupBy}}{{.GroupBy}}{{else}}hour{{end}}';
var trendUrl = '/admin/usage/trend?groupBy=' + trendGb + '{{if .FilterStart}}&start={{.FilterStart}}{{end}}{{if .FilterEnd}}&end={{.FilterEnd}}{{end}}{{if .FilterModel}}&model={{.FilterModel}}{{end}}';

function formatTokens(n){
  if(n===0)return '0';
  if(n<10000)return String(n);
  if(n<1000000)return(Math.round(n/100)/10).toFixed(1)+'K';
  return(Math.round(n/10000)/100).toFixed(2)+'M';
}

function renderTrend(data){
  if(!data.length){
    document.getElementById('trendChart').innerHTML = '<div class="no-data">No usage data for the selected filters</div>';
    return;
  }
  var dates = data.map(function(d){return d.date});
  var requests = data.map(function(d){return d.request_count});
  var total = data.map(function(d){return d.total_tokens});
  var cs = getComputedStyle(document.documentElement);
  var chartMuted = cs.getPropertyValue('--muted').trim() || '#8b9098';
  var chartLine = cs.getPropertyValue('--line').trim() || 'rgba(210,214,220,.09)';
  var chart = echarts.init(document.getElementById('trendChart'));
  chart.setOption({
    backgroundColor:'transparent',
    tooltip:{trigger:'axis',axisPointer:{type:'cross'}},
    legend:{data:['Requests','Total Tokens'],textStyle:{color:chartMuted}},
    grid:{left:'3%',right:'4%',bottom:'3%',containLabel:true},
    xAxis:{type:'category',data:dates,axisLabel:{color:chartMuted}},
    yAxis:[
      {type:'value',name:'Requests',position:'left',axisLabel:{color:chartMuted},splitLine:{lineStyle:{color:chartLine}}},
      {type:'value',name:'Tokens',position:'right',axisLabel:{formatter:function(v){return formatTokens(v)},color:chartMuted},splitLine:{show:false}}
    ],
    series:[
      {name:'Requests',type:'line',yAxisIndex:0,smooth:true,areaStyle:{opacity:0.045},data:requests,itemStyle:{color:'#aeb2ba'}},
      {name:'Total Tokens',type:'line',yAxisIndex:1,smooth:true,areaStyle:{opacity:0.055},data:total,itemStyle:{color:'#8b5cf6'}}
    ]
  });
  window.addEventListener('resize',function(){chart.resize()});
}

function loadTrend(groupBy){
  var url = '/admin/usage/trend?groupBy=' + groupBy + '{{if .FilterStart}}&start={{.FilterStart}}{{end}}{{if .FilterEnd}}&end={{.FilterEnd}}{{end}}{{if .FilterModel}}&model={{.FilterModel}}{{end}}';
  fetch(url).then(function(r){return r.json()}).then(renderTrend);
}

document.querySelectorAll('.gb-btn').forEach(function(btn){
  btn.addEventListener('click',function(){
    var gb = btn.dataset.group;
    document.querySelectorAll('.gb-btn').forEach(function(b){b.classList.remove('active')});
    btn.classList.add('active');
    loadTrend(gb);
  });
});

loadTrend(trendGb);
</script>
{{else if eq .View "by_model"}}
{{if .ModelSummaries}}
<script id="modelPieData" type="application/json">{{range $i, $s := .ModelSummaries}}{{if $i}},{{end}}{"name":"{{.Model}}","tokens":{{.TotalTokens}},"requests":{{.RequestCount}}}{{end}}</script>
<div class="pie-controls">
  <span>By:</span>
  <button type="button" class="pm-btn{{if eq .PieMetric "tokens"}} active{{end}}" data-metric="tokens">Tokens</button>
  <button type="button" class="pm-btn{{if eq .PieMetric "requests"}} active{{end}}" data-metric="requests">Requests</button>
</div>
<div id="modelPieChart" class="pie-chart"></div>
<div class="table-wrap"><table><thead><tr><th>Model</th><th>Requests</th><th>Success</th><th>Errors</th><th>Total Tokens</th><th>Active Keys</th></tr></thead><tbody>
{{range .ModelSummaries}}<tr><td>{{.Model}}</td><td>{{.RequestCount}}</td><td>{{.SuccessCount}}</td><td>{{.ErrorCount}}</td><td class="token-cell" data-tokens="{{.TotalTokens}}">{{.TotalTokens}}</td><td>{{.KeyCount}}</td></tr>{{end}}
</tbody></table></div>
{{else}}
<div class="no-data">No usage data for the selected filters</div>
{{end}}
{{else}}
{{if .Usage}}
<script id="keyPieData" type="application/json">{{range $i, $u := .Usage}}{{if $i}},{{end}}{"name":"{{if .KeyName}}{{.KeyName}}{{else}}{{maskID .KeyID}}{{end}}","tokens":{{.TotalTokens}},"requests":{{.RequestCount}}}{{end}}</script>
<div class="pie-controls">
  <span>By:</span>
  <button type="button" class="pm-btn{{if eq .PieMetric "tokens"}} active{{end}}" data-metric="tokens">Tokens</button>
  <button type="button" class="pm-btn{{if eq .PieMetric "requests"}} active{{end}}" data-metric="requests">Requests</button>
</div>
<div id="keyPieChart" class="pie-chart"></div>
<div class="table-wrap"><table><thead><tr><th>Name</th>{{if .IsAdmin}}<th>Owner</th>{{end}}<th>Purpose</th><th>Requests</th><th>Success</th><th>Errors</th><th>Total Tokens</th></tr></thead><tbody>
{{range .Usage}}<tr><td>{{.KeyName}}</td>{{if $.IsAdmin}}<td>{{.Owner}}</td>{{end}}<td>{{.Purpose}}</td><td>{{.RequestCount}}</td><td>{{.SuccessCount}}</td><td>{{.ErrorCount}}</td><td class="token-cell" data-tokens="{{.TotalTokens}}">{{.TotalTokens}}</td></tr>{{end}}
</tbody></table></div>
{{else}}
<div class="no-data">No usage data for the selected filters</div>
{{end}}
{{end}}
<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
<script>
function formatTokensTable(n){
  if(n<10000)return String(n);
  if(n<1000000)return(Math.round(n/100)/10).toFixed(1)+'K';
  return(Math.round(n/10000)/100).toFixed(2)+'M';
}
document.querySelectorAll('.token-cell').forEach(function(el){
  var n=parseInt(el.dataset.tokens,10);
  if(!isNaN(n)&&n>=10000){el.textContent=formatTokensTable(n);}
});

function formatPieValue(metric, n){
  if(metric==='requests') return String(n) + ' requests';
  if(n<10000) return String(n) + ' tokens';
  if(n<1000000) return (Math.round(n/100)/10).toFixed(1)+'K tokens';
  return (Math.round(n/10000)/100).toFixed(2)+'M tokens';
}

function renderPieChart(chartId, dataElId, metric){
  var el=document.getElementById(dataElId);
  if(!el||!el.textContent.trim())return null;
  var rawData=JSON.parse('['+el.textContent+']');
  var data=rawData.map(function(d){
    return {name:d.name, value: metric==='requests'? d.requests : d.tokens};
  });
  var formatter = function(item){
    var raw = rawData.find(function(d){return d.name===item.name});
    var val = metric==='requests'? raw.requests : raw.tokens;
    return item.name + ': ' + formatPieValue(metric, val) + ' (' + item.percent + '%)';
  };
  var cs = getComputedStyle(document.documentElement);
  var chartTextStrong = cs.getPropertyValue('--text-strong').trim() || '#e1e5eb';
  var chart=echarts.init(document.getElementById(chartId));
  chart._pieRawData = rawData;
  chart.setOption({
    backgroundColor:'transparent',
    tooltip:{trigger:'item',formatter:formatter},
    series:[{type:'pie',radius:['40%','70%'],avoidLabelOverlap:false,label:{color:chartTextStrong},labelLine:{show:true},data:data}]
  });
  window.addEventListener('resize',function(){chart.resize()});
  return chart;
}

function updatePieChart(chart, metric){
  var rawData = chart._pieRawData;
  var data=rawData.map(function(d){
    return {name:d.name, value: metric==='requests'? d.requests : d.tokens};
  });
  var formatter = function(item){
    var raw = rawData.find(function(d){return d.name===item.name});
    var val = metric==='requests'? raw.requests : raw.tokens;
    return item.name + ': ' + formatPieValue(metric, val) + ' (' + item.percent + '%)';
  };
  chart.setOption({
    tooltip:{trigger:'item',formatter:formatter},
    series:[{data:data}]
  });
}

{{if eq .View "by_model"}}
(function(){
  var initialMetric = '{{.PieMetric}}' || 'tokens';
  var chart = renderPieChart('modelPieChart', 'modelPieData', initialMetric);
  if(!chart) return;
  document.querySelectorAll('.pm-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var metric = btn.dataset.metric;
      document.querySelectorAll('.pm-btn').forEach(function(b){b.classList.remove('active')});
      btn.classList.add('active');
      updatePieChart(chart, metric);
    });
  });
})();
{{else if eq .View "by_key"}}
(function(){
  var initialMetric = '{{.PieMetric}}' || 'tokens';
  var chart = renderPieChart('keyPieChart', 'keyPieData', initialMetric);
  if(!chart) return;
  document.querySelectorAll('.pm-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var metric = btn.dataset.metric;
      document.querySelectorAll('.pm-btn').forEach(function(b){b.classList.remove('active')});
      btn.classList.add('active');
      updatePieChart(chart, metric);
    });
  });
})();
{{end}}
</script>
</div>{{template "admin_theme_toggle" .}}</body></html>
