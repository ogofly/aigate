<!doctype html>
<html lang="{{.Lang}}"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{.Title}}</title>{{template "admin_head_assets" .}}
{{template "admin_theme_init" .}}
<style>
{{template "admin_common_styles" .}}
.page-intro{margin:0 0 16px}
.filters{display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;margin-top:12px}
.filters label{display:flex;flex-direction:column;gap:6px;font-size:13px;min-width:0}
.filter-actions{display:flex;gap:8px;align-items:center;padding-bottom:6px}
.filter-actions button{min-height:40px;padding:10px 14px}
.quick-dates{display:flex;gap:6px;align-items:center;flex-wrap:wrap;padding-bottom:6px}
.quick-dates button{min-height:40px;padding:10px 12px}
a.clear-filters{color:var(--muted);text-decoration:none;font-size:13px}
.section-card{margin-top:16px}
.section-card:first-of-type{margin-top:0}
.section-toggle-row{display:flex;align-items:center;justify-content:space-between;gap:12px}
.section-title{margin:0}
.section-toggle{display:flex;align-items:center;gap:8px;padding:0;border:0;background:none;color:var(--text-strong);box-shadow:none;font:inherit;font-size:16px;font-weight:600}
.section-toggle:hover{transform:none;background:none;border:0;color:var(--text-strong)}
.section-toggle:focus-visible{outline:2px solid rgba(139,92,246,.35);outline-offset:4px;border-radius:4px}
.section-toggle-indicator{display:inline-block;color:var(--text);font-size:20px;font-weight:700;line-height:1;transition:transform .18s ease,opacity .18s ease;opacity:.9}
.section-toggle:hover .section-toggle-indicator{opacity:1}
.section-toggle[aria-expanded="false"] .section-toggle-indicator{transform:rotate(-90deg)}
.section-body{margin-top:10px}
.section-body[hidden]{display:none}
#trendChart{width:100%;height:400px;margin-top:16px}
.trend-controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:12px;font-size:13px}
.trend-controls button,.pie-controls button{padding:6px 12px;font-size:13px;border:1px solid var(--line);background:rgba(210,214,220,.022);color:var(--muted);border-radius:4px;cursor:pointer;transition:background-color .18s ease,border-color .18s ease,color .18s ease,box-shadow .18s ease}
.trend-controls button:hover,.pie-controls button:hover{background:rgba(210,214,220,.032);color:var(--text)}
.trend-controls button.active,.pie-controls button.active{background:rgba(210,214,220,.04);color:var(--text-strong);border-color:rgba(139,92,246,.26);box-shadow:inset 0 0 0 1px rgba(139,92,246,.1)}
.chart-group{margin-top:16px;padding-bottom:4px;border-bottom:1px solid var(--line)}
.chart-group:last-child{border-bottom:0;padding-bottom:0}
.chart-group .table-wrap{max-height:500px;overflow-y:auto}
.table-wrap::-webkit-scrollbar{width:8px}
.table-wrap::-webkit-scrollbar-thumb{background:var(--line);border-radius:4px}
.table-wrap::-webkit-scrollbar-track{background:transparent}
.pie-chart{width:100%;height:300px;margin:16px 0}
.pie-controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:12px;font-size:13px}
.sort-btn{background:none;border:0;color:inherit;padding:0;cursor:pointer;font:inherit;transition:color .18s ease}
.sort-btn:hover{color:var(--text-strong)}
.no-data{text-align:center;padding:28px;color:var(--muted);font-size:15px}
.usage-page .table-wrap{border-left:0;border-right:0;border-radius:0;box-shadow:none;margin-left:-14px;margin-right:-14px;width:calc(100% + 28px)}
.usage-page th,.usage-page td{padding-left:4px;padding-right:4px}
@media (max-width:960px){
.filters{grid-template-columns:repeat(2,minmax(0,1fr))}
}
@media (max-width:720px){
.filters{grid-template-columns:repeat(2,minmax(0,1fr))}
#trendChart{height:300px}
.pie-chart{height:240px}
}
</style>
</head><body class="usage-page"><div class="page">
{{template "admin_nav" .}}
<h1>{{.T "Usage"}}</h1>
<section class="panel">
<h2 class="panel-title">{{.T "Usage Analytics"}}</h2>
<p class="panel-copy page-intro">{{.T "Trend, key, and model views share the same filters and render together on one page."}}</p>
<form method="get" action="/admin/usage/view" class="filters">
  <label>{{.T "Start Date"}} <input type="date" name="start" value="{{.FilterStart}}"></label>
  <label>{{.T "End Date"}} <input type="date" name="end" value="{{.FilterEnd}}"></label>
  <label>{{.T "Model"}} <select name="model"><option value="">{{.T "All"}}</option>{{range .UsageModels}}<option value="{{.}}" {{if eq . $.FilterModel}}selected{{end}}>{{.}}</option>{{end}}</select></label>
  <label>{{.T "Provider"}} <select name="provider"><option value="">{{.T "All"}}</option>{{range .UsageProviders}}<option value="{{.}}" {{if eq . $.FilterProvider}}selected{{end}}>{{.}}</option>{{end}}</select></label>
  <label>{{.T "Key"}} <select name="key"><option value="">{{.T "All"}}</option>{{range .UsageKeys}}<option value="{{.Value}}" {{if eq .Value $.FilterKey}}selected{{end}}>{{.Label}}</option>{{end}}</select></label>
  {{if .IsAdmin}}<label>{{.T "User"}} <select name="owner"><option value="">{{.T "All"}}</option>{{range .UsageOwners}}<option value="{{.}}" {{if eq . $.FilterOwner}}selected{{end}}>{{.}}</option>{{end}}</select></label>{{end}}
  <div class="quick-dates" aria-label="{{.T "Quick date filters"}}">
    <button type="button" class="ghost" onclick="setQuickDate(1)">{{.T "Today"}}</button>
    <button type="button" class="ghost" onclick="setQuickDate(7)">{{.T "7d"}}</button>
    <button type="button" class="ghost" onclick="setQuickDate(30)">{{.T "30d"}}</button>
  </div>
  <div class="filter-actions">
    <button type="submit">{{.T "Filter"}}</button>
    {{if or .FilterStart .FilterEnd .FilterModel .FilterProvider .FilterKey .FilterOwner}}<a class="clear-filters" href="/admin/usage/view">{{.T "Clear Filters"}}</a>{{end}}
  </div>
</form>
</section>

<section class="panel section-card">
<div class="section-toggle-row">
<h2 class="panel-title section-title"><button type="button" class="section-toggle" data-section-target="trendSectionBody" data-resize-target="trendChart" aria-expanded="true">{{.T "Trend"}} <span class="section-toggle-indicator">▾</span></button></h2>
</div>
<div id="trendSectionBody" class="section-body">
<div id="trendControls" class="trend-controls">
  <span>{{.T "Granularity:"}}</span>
  <button type="button" class="gb-btn active" data-group="hour">{{.T "Hour"}}</button>
  <button type="button" class="gb-btn" data-group="day">{{.T "Day"}}</button>
</div>
<script id="trendHourData" type="application/json">{{range $i, $p := .TrendHourPoints}}{{if $i}},{{end}}{"date":"{{.Date}}","request_count":{{.RequestCount}},"error_count":{{.ErrorCount}},"total_tokens":{{.TotalTokens}}}{{end}}</script>
<script id="trendDayData" type="application/json">{{range $i, $p := .TrendDayPoints}}{{if $i}},{{end}}{"date":"{{.Date}}","request_count":{{.RequestCount}},"error_count":{{.ErrorCount}},"total_tokens":{{.TotalTokens}}}{{end}}</script>
<div id="trendChart">{{if not (or .TrendHourPoints .TrendDayPoints)}}<div class="no-data">{{.T "No usage data for the selected filters"}}</div>{{end}}</div>
</div>
</section>

<section class="panel section-card">
<div class="section-toggle-row">
<h2 class="panel-title section-title"><button type="button" class="section-toggle" data-section-target="modelSectionBody" data-resize-target="modelPieChart" aria-expanded="true">{{.T "By Model"}} <span class="section-toggle-indicator">▾</span></button></h2>
</div>
<div id="modelSectionBody" class="section-body">
{{if .ModelSummaries}}
<script id="modelPieData" type="application/json">{{range $i, $s := .ModelSummaries}}{{if $i}},{{end}}{"name":"{{.Model}}","tokens":{{.TotalTokens}},"requests":{{.RequestCount}}}{{end}}</script>
<div class="chart-group">
<div class="pie-controls">
  <span>{{.T "By:"}}</span>
  <button type="button" class="pm-btn-model{{if eq .PieMetric "tokens"}} active{{end}}" data-metric="tokens">{{.T "Tokens"}}</button>
  <button type="button" class="pm-btn-model{{if eq .PieMetric "requests"}} active{{end}}" data-metric="requests">{{.T "Requests"}}</button>
</div>
<div id="modelPieChart" class="pie-chart"></div>
<div class="table-wrap"><table id="model-table"><thead><tr>
<th><button type="button" class="sort-btn" onclick="sortTable('model-table',0,'text')">{{.T "Model"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('model-table',1,'num')">{{.T "Requests"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('model-table',2,'num')">{{.T "Success"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('model-table',3,'num')">{{.T "Errors"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('model-table',4,'num')">{{.T "Total Tokens"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('model-table',5,'num')">{{.T "Active Keys"}}</button></th>
</tr></thead><tbody>
{{range .ModelSummaries}}<tr><td>{{.Model}}</td><td>{{.RequestCount}}</td><td>{{.SuccessCount}}</td><td>{{.ErrorCount}}</td><td class="token-cell" data-tokens="{{.TotalTokens}}">{{.TotalTokens}}</td><td>{{.KeyCount}}</td></tr>{{end}}
</tbody></table></div>
</div>
{{else}}
<div class="no-data">{{.T "No usage data for the selected filters"}}</div>
{{end}}
</div>
</section>

<section class="panel section-card">
<div class="section-toggle-row">
<h2 class="panel-title section-title"><button type="button" class="section-toggle" data-section-target="keySectionBody" data-resize-target="keyPieChart" aria-expanded="true">{{.T "By Key"}} <span class="section-toggle-indicator">▾</span></button></h2>
</div>
<div id="keySectionBody" class="section-body">
{{if .Usage}}
<script id="keyPieData" type="application/json">{{range $i, $u := .Usage}}{{if $i}},{{end}}{"name":"{{if .KeyName}}{{.KeyName}}{{else}}{{maskID .KeyID}}{{end}}","tokens":{{.TotalTokens}},"requests":{{.RequestCount}}}{{end}}</script>
<div class="chart-group">
<div class="pie-controls">
  <span>{{.T "By:"}}</span>
  <button type="button" class="pm-btn-key{{if eq .PieMetric "tokens"}} active{{end}}" data-metric="tokens">{{.T "Tokens"}}</button>
  <button type="button" class="pm-btn-key{{if eq .PieMetric "requests"}} active{{end}}" data-metric="requests">{{.T "Requests"}}</button>
</div>
<div id="keyPieChart" class="pie-chart"></div>
<div class="table-wrap"><table id="key-table"><thead><tr>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',0,'text')">{{.T "Name"}}</button></th>
{{if .IsAdmin}}<th><button type="button" class="sort-btn" onclick="sortTable('key-table',1,'text')">{{.T "User"}}</button></th>{{end}}
{{if .IsAdmin}}
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',2,'text')">{{.T "Purpose"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',3,'num')">{{.T "Requests"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',4,'num')">{{.T "Success"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',5,'num')">{{.T "Errors"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',6,'num')">{{.T "Total Tokens"}}</button></th>
{{else}}
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',1,'text')">{{.T "Purpose"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',2,'num')">{{.T "Requests"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',3,'num')">{{.T "Success"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',4,'num')">{{.T "Errors"}}</button></th>
<th><button type="button" class="sort-btn" onclick="sortTable('key-table',5,'num')">{{.T "Total Tokens"}}</button></th>
{{end}}
</tr></thead><tbody>
{{range .Usage}}<tr><td>{{if .KeyName}}{{.KeyName}}{{else}}{{maskID .KeyID}}{{end}}</td>{{if $.IsAdmin}}<td>{{.Owner}}</td>{{end}}<td>{{.Purpose}}</td><td>{{.RequestCount}}</td><td>{{.SuccessCount}}</td><td>{{.ErrorCount}}</td><td class="token-cell" data-tokens="{{.TotalTokens}}">{{.TotalTokens}}</td></tr>{{end}}
</tbody></table></div>
</div>
{{else}}
<div class="no-data">{{.T "No usage data for the selected filters"}}</div>
{{end}}
</div>
</section>

<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
<script>
function readJSONList(id){
  var el=document.getElementById(id);
  if(!el||!el.textContent.trim())return [];
  return JSON.parse('['+el.textContent+']');
}

function localDateString(date){
  var y = date.getFullYear();
  var m = String(date.getMonth() + 1).padStart(2, '0');
  var d = String(date.getDate()).padStart(2, '0');
  return y + '-' + m + '-' + d;
}

function setQuickDate(days){
  var form = document.querySelector('form.filters');
  if(!form){return;}
  var end = new Date();
  var start = new Date();
  start.setDate(end.getDate() - Math.max(days - 1, 0));
  form.querySelector('[name=start]').value = localDateString(start);
  form.querySelector('[name=end]').value = localDateString(end);
  form.submit();
}

function formatTokens(n){
  if(n===0)return '0';
  if(n<10000)return String(n);
  if(n<1000000)return(Math.round(n/100)/10).toFixed(1)+'K';
  return(Math.round(n/10000)/100).toFixed(2)+'M';
}

function formatTokensTable(n){
  if(n<10000)return String(n);
  if(n<1000000)return(Math.round(n/100)/10).toFixed(1)+'K';
  return(Math.round(n/10000)/100).toFixed(2)+'M';
}

document.querySelectorAll('.token-cell').forEach(function(el){
  var n=parseInt(el.dataset.tokens,10);
  if(!isNaN(n)&&n>=10000){el.textContent=formatTokensTable(n);}
});

function renderTrend(chart, data){
  if(!data.length){
    document.getElementById('trendChart').innerHTML = '<div class="no-data">' + {{toJSON (.T "No usage data for the selected filters")}} + '</div>';
    return null;
  }
  var dates = data.map(function(d){return d.date});
  var requests = data.map(function(d){return d.request_count});
  var errors = data.map(function(d){return d.error_count});
  var total = data.map(function(d){return d.total_tokens});
  var cs = getComputedStyle(document.documentElement);
  var chartMuted = cs.getPropertyValue('--muted').trim() || '#8b9098';
  var chartLine = cs.getPropertyValue('--line').trim() || 'rgba(210,214,220,.09)';
  chart.setOption({
    backgroundColor:'transparent',
    tooltip:{trigger:'axis',axisPointer:{type:'cross'},formatter:function(params){
      if(!params||!params.length)return '';
      var s=params[0].axisValue+'<br/>';
      for(var i=0;i<params.length;i++){
        var v=params[i].seriesName==={{toJSON (.T "Total Tokens")}}?formatTokensTable(params[i].data):params[i].data.toLocaleString();
        s+='<span style="display:inline-block;margin-right:4px;border-radius:50%;width:10px;height:10px;background-color:'+params[i].color+';"></span>';
        s+=params[i].seriesName+': '+v+'<br/>';
      }
      return s;
    }},
    legend:{data:[{{toJSON (.T "Requests")}},{{toJSON (.T "Errors")}},{{toJSON (.T "Total Tokens")}}],textStyle:{color:chartMuted}},
    grid:{left:'3%',right:'4%',bottom:'3%',containLabel:true},
    xAxis:{type:'category',data:dates,axisLabel:{color:chartMuted}},
    yAxis:[
      {type:'value',name:{{toJSON (.T "Requests")}},position:'left',axisLabel:{color:chartMuted},splitLine:{lineStyle:{color:chartLine}}},
      {type:'value',name:{{toJSON (.T "Tokens")}},position:'right',axisLabel:{formatter:function(v){return formatTokens(v)},color:chartMuted},splitLine:{show:false}}
    ],
    series:[
      {name:{{toJSON (.T "Requests")}},type:'line',yAxisIndex:0,smooth:true,areaStyle:{opacity:0.045},data:requests,itemStyle:{color:'#aeb2ba'}},
      {name:{{toJSON (.T "Errors")}},type:'line',yAxisIndex:0,smooth:true,areaStyle:{opacity:0.06},data:errors,itemStyle:{color:'#ef4444'}},
      {name:{{toJSON (.T "Total Tokens")}},type:'line',yAxisIndex:1,smooth:true,areaStyle:{opacity:0.055},data:total,itemStyle:{color:'#8b5cf6'}}
    ]
  });
  return chart;
}

function formatPieValue(metric, n){
  if(metric==='requests') return String(n) + ' ' + {{toJSON (.T "requests")}};
  if(n<10000) return String(n) + ' ' + {{toJSON (.T "tokens")}};
  if(n<1000000) return (Math.round(n/100)/10).toFixed(1)+'K ' + {{toJSON (.T "tokens")}};
  return (Math.round(n/10000)/100).toFixed(2)+'M ' + {{toJSON (.T "tokens")}};
}

function renderPieChart(chartId, dataElId, metric){
  var rawData=readJSONList(dataElId);
  if(!rawData.length)return null;
  var data=rawData.map(function(d){
    return {name:d.name, value: metric==='requests'? d.requests : d.tokens};
  });
  var formatter = function(item){
    var raw = rawData.find(function(d){return d.name===item.name});
    var val = metric==='requests'? raw.requests : raw.tokens;
    return item.name + ': ' + formatPieValue(metric, val) + ' (' + item.percent + '%)';
  };
  var cs = getComputedStyle(document.documentElement);
  var chartMuted = cs.getPropertyValue('--muted').trim() || '#8b9098';
  var chart=echarts.init(document.getElementById(chartId));
  chart._pieRawData = rawData;
  chart.setOption({
    backgroundColor:'transparent',
    tooltip:{trigger:'item',formatter:formatter},
    series:[{type:'pie',radius:['40%','70%'],avoidLabelOverlap:false,label:{color:chartMuted},labelLine:{show:true},data:data}]
  });
  window.addEventListener('resize',function(){chart.resize()});
  return chart;
}

function updatePieChart(chart, metric){
  var rawData = chart._pieRawData;
  var data=rawData.map(function(d){
    return {name:d.name, value: metric==='requests'? d.requests : d.tokens};
  });
  var formatter = function(item){
    var raw = rawData.find(function(d){return d.name===item.name});
    var val = metric==='requests'? raw.requests : raw.tokens;
    return item.name + ': ' + formatPieValue(metric, val) + ' (' + item.percent + '%)';
  };
  chart.setOption({
    tooltip:{trigger:'item',formatter:formatter},
    series:[{data:data}]
  });
}

(function(){
  document.querySelectorAll('.section-toggle').forEach(function(btn){
    btn.addEventListener('click', function(){
      var target = document.getElementById(btn.dataset.sectionTarget);
      if(!target){return;}
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      target.hidden = expanded;
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      if(expanded){return;}
      var resizeTarget = btn.dataset.resizeTarget;
      if(!resizeTarget){return;}
      var el = document.getElementById(resizeTarget);
      if(!el){return;}
      var chart = echarts.getInstanceByDom(el);
      if(chart){chart.resize();}
    });
  });
})();

(function(){
  var trendHourData = readJSONList('trendHourData');
  var trendDayData = readJSONList('trendDayData');
  if(!trendHourData.length && !trendDayData.length){
    document.getElementById('trendChart').innerHTML = '<div class="no-data">' + {{toJSON (.T "No usage data for the selected filters")}} + '</div>';
    return;
  }
  var chart = echarts.init(document.getElementById('trendChart'));
  window.addEventListener('resize',function(){chart.resize()});
  renderTrend(chart, trendHourData.length ? trendHourData : trendDayData);
  document.querySelectorAll('.gb-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var group = btn.dataset.group;
      document.querySelectorAll('.gb-btn').forEach(function(b){b.classList.remove('active')});
      btn.classList.add('active');
      renderTrend(chart, group === 'day' ? trendDayData : trendHourData);
    });
  });
})();

(function(){
  var initialMetric = '{{.PieMetric}}' || 'tokens';
  var chart = renderPieChart('keyPieChart', 'keyPieData', initialMetric);
  if(!chart) return;
  document.querySelectorAll('.pm-btn-key').forEach(function(btn){
    btn.addEventListener('click', function(){
      var metric = btn.dataset.metric;
      document.querySelectorAll('.pm-btn-key').forEach(function(b){b.classList.remove('active')});
      btn.classList.add('active');
      updatePieChart(chart, metric);
    });
  });
})();

(function(){
  var initialMetric = '{{.PieMetric}}' || 'tokens';
  var chart = renderPieChart('modelPieChart', 'modelPieData', initialMetric);
  if(!chart) return;
  document.querySelectorAll('.pm-btn-model').forEach(function(btn){
    btn.addEventListener('click', function(){
      var metric = btn.dataset.metric;
      document.querySelectorAll('.pm-btn-model').forEach(function(b){b.classList.remove('active')});
      btn.classList.add('active');
      updatePieChart(chart, metric);
    });
  });
})();

function sortTable(tableId, col, kind){
  const table = document.getElementById(tableId);
  if(!table || !table.tBodies || table.tBodies.length === 0){return;}
  const tbody = table.tBodies[0];
  const rows = Array.from(tbody.rows);
  if(rows.length === 0){return;}
  const isSameCol = table.dataset.sortCol === String(col);
  const nextAsc = isSameCol ? table.dataset.sortAsc !== "true" : kind !== "num";
  rows.sort((a, b) => {
    let av = (a.cells[col]?.textContent || "").trim();
    let bv = (b.cells[col]?.textContent || "").trim();
    if(kind === "num"){
      const aCell = a.cells[col];
      const bCell = b.cells[col];
      const aTokens = aCell?.dataset.tokens || aCell?.querySelector("[data-tokens]")?.dataset.tokens;
      const bTokens = bCell?.dataset.tokens || bCell?.querySelector("[data-tokens]")?.dataset.tokens;
      if(aTokens || bTokens){
        av = aTokens || av;
        bv = bTokens || bv;
      }
      const an = Number.parseInt(av.replace(/[^0-9.-]/g,""), 10) || 0;
      const bn = Number.parseInt(bv.replace(/[^0-9.-]/g,""), 10) || 0;
      return nextAsc ? an - bn : bn - an;
    }
    return nextAsc ? av.localeCompare(bv) : bv.localeCompare(av);
  });
  for(const row of rows){tbody.appendChild(row);}
  table.dataset.sortCol = String(col);
  table.dataset.sortAsc = nextAsc ? "true" : "false";
}

(function(){
  {{if .ModelSummaries}}
  sortTable('model-table', 4, 'num');
  {{end}}
  {{if .Usage}}
  sortTable('key-table', {{if .IsAdmin}}6{{else}}5{{end}}, 'num');
  {{end}}
})();
</script>
</div>{{template "admin_theme_toggle" .}}</body></html>
