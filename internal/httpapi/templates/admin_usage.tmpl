<!doctype html>
<html><head><meta charset="utf-8"><title>{{.Title}}</title>
<style>body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;max-width:1280px;margin:32px auto;padding:0 16px;color:#fffffe;background:#16161a}nav a{margin-right:16px;color:#fffffe;text-decoration:none}table{width:100%;border-collapse:collapse;margin-top:24px;background:rgba(255,255,255,.03)}th,td{padding:10px;border-bottom:1px solid #72757e;text-align:left}button{padding:8px 12px;border:0;background:#7f5af0;color:#fffffe;border-radius:8px;cursor:pointer;font-weight:600}.muted{color:#94a1b2}</style>
</head><body>{{template "admin_nav" .}}<h1>Usage</h1><table><thead><tr><th>Key ID</th><th>Name</th>{{if .IsAdmin}}<th>Owner</th>{{end}}<th>Purpose</th><th>Requests</th><th>Success</th><th>Errors</th><th>Total Tokens</th></tr></thead><tbody>{{range .Usage}}<tr><td>{{.KeyID}}</td><td>{{.KeyName}}</td>{{if $.IsAdmin}}<td>{{.Owner}}</td>{{end}}<td>{{.Purpose}}</td><td>{{.RequestCount}}</td><td>{{.SuccessCount}}</td><td>{{.ErrorCount}}</td><td>{{.TotalTokens}}</td></tr>{{else}}<tr><td colspan="{{if .IsAdmin}}8{{else}}7{{end}}" class="muted">No usage yet</td></tr>{{end}}</tbody></table></body></html>
