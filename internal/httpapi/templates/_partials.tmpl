<aside id="navBackdrop" class="nav-backdrop"></aside>
<script>(function(){
  var d=document.getElementById('navDrawer'),t=document.querySelector('.nav-hamburger');
  if(!d||!t)return;
  function o(){d.showModal()}
  function c(){d.close()}
  t.addEventListener('click',function(){d.open?c():o()});
  d.addEventListener('click',function(e){if(e.target===d)c()});
  d.querySelectorAll('.nav-drawer-link').forEach(function(a){a.addEventListener('click',c)});
})();</script>
{{end}}
