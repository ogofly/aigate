{{define "admin_api_helpers"}}
<script>
async function submitFormAjax(form, onSuccess){
  try{
    var m = (form.getAttribute('method') || 'POST').toUpperCase();
    if(m === 'GET' || m === 'HEAD') m = 'POST';
    const resp = await fetch(form.action, {
      method: m,
      headers: {'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json'},
      body: new FormData(form),
    });
    const parsed = await readAPIResponse(resp);
    if(isLoginRedirect(resp)){
      showAjaxError({{toJSON (.T "Session expired. Please sign in again.")}}, responseDetails(resp, parsed));
      return;
    }
    if(!resp.ok){
      showAjaxError(parsed.data?.error?.message || ({{toJSON (.T "Request failed")}} + ' (HTTP ' + resp.status + ')'), responseDetails(resp, parsed));
      return;
    }
    if(!parsed.data){
      showAjaxError({{toJSON (.T "Unexpected server response. Please refresh and try again.")}}, responseDetails(resp, parsed));
      return;
    }
    if(parsed.data.ok && onSuccess) onSuccess(parsed.data);
  }catch(e){
    showAjaxError({{toJSON (.T "Network error: ")}}+e.message, e.stack || String(e));
  }
}

function showAjaxError(msg, details){
  var host = currentErrorHost();
  var el = host === document.body ? document.getElementById('ajaxErrorToast') : host.querySelector('.ajax-error-toast');
  if(!el){
    el = document.createElement('div');
    el.className = 'ajax-error-toast';
    el.setAttribute('role', 'alert');
    el.setAttribute('aria-live', 'assertive');
    if(host === document.body){el.id = 'ajaxErrorToast';}
    el.innerHTML = '<div class="ajax-error-inner"><div class="ajax-error-main"><span class="ajax-error-text"></span><button type="button" class="ajax-error-details-toggle" onclick="toggleAjaxErrorDetails(this)">{{.T "Details"}}</button><button type="button" class="ajax-error-close" onclick="closeAjaxError(this)" aria-label="{{.T "Close error"}}">\u00d7</button></div><pre class="ajax-error-details"></pre></div>';
    if(host === document.body){
      document.body.appendChild(el);
    }else{
      host.insertBefore(el, host.querySelector('.modal-form') || host.firstChild);
    }
  }
  el.querySelector('.ajax-error-text').textContent = msg;
  var detailsToggle = el.querySelector('.ajax-error-details-toggle');
  var detailsEl = el.querySelector('.ajax-error-details');
  if(details){
    detailsToggle.style.display = 'inline-flex';
    detailsToggle.textContent = {{toJSON (.T "Details")}};
    detailsEl.textContent = details;
    detailsEl.style.display = 'none';
  }else{
    detailsToggle.style.display = 'none';
    detailsEl.textContent = '';
    detailsEl.style.display = 'none';
  }
  el.style.display = 'block';
}

function closeAjaxError(btn){
  var el = btn ? btn.closest('.ajax-error-toast') : document.getElementById('ajaxErrorToast');
  if(el){el.style.display = 'none';}
}

function toggleAjaxErrorDetails(btn){
  var box = btn.closest('.ajax-error-inner').querySelector('.ajax-error-details');
  var open = box.style.display === 'block';
  box.style.display = open ? 'none' : 'block';
  btn.textContent = open ? {{toJSON (.T "Details")}} : {{toJSON (.T "Hide")}};
}

function showToast(message){
  var el = document.getElementById('adminToast');
  if(!el){
    el = document.createElement('div');
    el.id = 'adminToast';
    el.className = 'admin-toast';
    el.setAttribute('role', 'status');
    el.setAttribute('aria-live', 'polite');
    document.body.appendChild(el);
  }
  el.textContent = message;
  el.style.display = 'block';
  window.clearTimeout(el._hideTimer);
  el._hideTimer = window.setTimeout(function(){el.style.display = 'none';}, 1800);
}

function reloadAfterToast(message){
  showToast(message);
  window.setTimeout(function(){location.reload();}, 450);
}

function currentErrorHost(){
  var openDialog = document.querySelector('dialog.modal-dialog[open] .modal-inner');
  return openDialog || document.body;
}

function isLoginRedirect(resp){
  if(!resp.redirected){return false;}
  try {
    return new URL(resp.url).pathname === '/admin/login';
  } catch (_e) {
    return false;
  }
}

async function readAPIResponse(resp){
  const contentType = resp.headers.get('Content-Type') || '';
  const text = await resp.text().catch(() => '');
  var data = null;
  if(contentType.toLowerCase().includes('application/json') && text){
    try {
      data = JSON.parse(text);
    } catch (_e) {
      data = null;
    }
  }
  return {contentType: contentType, data: data, text: text};
}

function responseDetails(resp, parsed){
  var body = parsed.data ? JSON.stringify(parsed.data, null, 2) : parsed.text;
  if(!body){body = '(empty body)';}
  return [
    'HTTP ' + resp.status + ' ' + resp.statusText,
    'URL: ' + resp.url,
    'Content-Type: ' + (parsed.contentType || '-'),
    '',
    body,
  ].join('\n');
}

async function apiCall(method, path, body){
  const opts = {
    method: method,
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
  };
  if (body) opts.body = JSON.stringify(body);
  try {
    const resp = await fetch(path, opts);
    const parsed = await readAPIResponse(resp);
    if(isLoginRedirect(resp)){
      showAjaxError({{toJSON (.T "Session expired. Please sign in again.")}}, responseDetails(resp, parsed));
      return null;
    }
    if (!resp.ok) {
      showAjaxError(parsed.data?.error?.message || ({{toJSON (.T "Request failed")}} + ' (HTTP ' + resp.status + ')'), responseDetails(resp, parsed));
      return null;
    }
    if(!parsed.data){
      showAjaxError({{toJSON (.T "Unexpected server response. Please refresh and try again.")}}, responseDetails(resp, parsed));
      return null;
    }
    return parsed.data;
  } catch (e) {
    showAjaxError({{toJSON (.T "Network error: ")}} + e.message, e.stack || String(e));
    return null;
  }
}
</script>
{{end}}

{{define "admin_copy_helpers"}}
<script>
async function copyWithFallback(value){
  if (navigator.clipboard && window.isSecureContext) {
    await navigator.clipboard.writeText(value);
    return;
  }
  const textArea = document.createElement("textarea");
  textArea.value = value;
  textArea.setAttribute("readonly", "");
  textArea.style.position = "fixed";
  textArea.style.left = "-9999px";
  document.body.appendChild(textArea);
  textArea.select();
  const ok = document.execCommand("copy");
  document.body.removeChild(textArea);
  if (!ok) {
    throw new Error("copy failed");
  }
}
</script>
{{end}}

