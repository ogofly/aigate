{{define "admin_common_styles"}}
:root{--bg:#13161a;--card:rgba(210,214,220,.04);--line:rgba(210,214,220,.09);--line-strong:rgba(210,214,220,.14);--text:#c3c8cf;--text-strong:#e1e5eb;--muted:#8b9098;--accent:#8b5cf6;--accent-strong:#7c3aed;--accent-soft:rgba(139,92,246,.08);--ghost:rgba(210,214,220,.025);--surface:rgba(210,214,220,.03);--shadow:0 10px 22px rgba(0,0,0,.18)}
[data-theme="light"]{--bg:#f5f6f8;--card:#fff;--line:#e2e4e8;--line-strong:#d1d4da;--text:#3d4149;--text-strong:#1a1d22;--muted:#6b7280;--accent:#7c3aed;--accent-strong:#6d28d9;--accent-soft:rgba(124,58,237,.06);--ghost:#f3f4f6;--surface:#f8f9fb;--shadow:0 10px 22px rgba(0,0,0,.07)}
*{box-sizing:border-box}
html{-webkit-text-size-adjust:100%}
body{margin:0;position:relative;overflow-x:clip;min-height:100vh;background:radial-gradient(circle at top, rgba(210,214,220,.028), transparent 22%),linear-gradient(180deg, #181b1f 0%, #15181c 44%, var(--bg) 100%);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,sans-serif;line-height:1.36;padding:24px 16px}
body::before{content:"";position:fixed;inset:0;background-image:linear-gradient(rgba(210,214,220,.007) 1px, transparent 1px),linear-gradient(90deg, rgba(210,214,220,.006) 1px, transparent 1px);background-size:32px 32px;opacity:.1;pointer-events:none}
.page{position:relative;z-index:1;max-width:1280px;margin:0 auto}
h1{margin:0 0 12px;font-size:28px;letter-spacing:0;color:var(--text-strong)}
h2,h3{margin:0}
a{color:var(--text)}
button,input,select,textarea{font:inherit}
label{display:block;font-size:13px;color:var(--muted);margin-bottom:6px}
input,select,textarea{width:100%;max-width:100%;padding:10px 12px;border:1px solid var(--line);border-radius:3px;background:rgba(28,30,35,.8);color:var(--text);box-shadow:inset 0 1px 0 rgba(210,214,220,.02);transition:border-color .18s ease,box-shadow .18s ease,background-color .18s ease}
select option{background:#1c1e23;color:var(--text)}
input::placeholder,textarea::placeholder{color:#686d77}
input:focus,select:focus,textarea:focus{outline:none;border-color:rgba(139,92,246,.42);box-shadow:0 0 0 2px rgba(139,92,246,.09);background:rgba(31,34,39,.94)}
button{padding:8px 11px;border:1px solid var(--line);background:linear-gradient(180deg, rgba(210,214,220,.054), rgba(210,214,220,.028));color:var(--text);border-radius:4px;cursor:pointer;font-size:13px;font-weight:600;box-shadow:0 4px 10px rgba(0,0,0,.1),inset 0 1px 0 rgba(210,214,220,.03);transition:transform .18s ease,border-color .18s ease,background-color .18s ease,box-shadow .18s ease,color .18s ease}
button:hover{border-color:rgba(139,92,246,.52);background:linear-gradient(180deg, rgba(210,214,220,.072), rgba(210,214,220,.035));transform:translateY(-1px)}
button:active{transform:translateY(0)}
.ghost{background:var(--ghost);color:var(--muted);box-shadow:none;border:1px solid rgba(210,214,220,.075)}
.ghost:hover{color:var(--text);background:rgba(210,214,220,.038)}
.muted{color:var(--muted)}
.flash{padding:12px 14px;background:rgba(210,214,220,.038);border:1px solid rgba(139,92,246,.12);border-radius:4px;margin-top:16px;color:var(--text)}
.panel{position:relative;padding:18px;border:1px solid var(--line);border-radius:4px;background:linear-gradient(180deg, rgba(210,214,220,.042), rgba(210,214,220,.026));box-shadow:var(--shadow);transition:border-color .18s ease,background-color .18s ease}
.panel::before{content:"";position:absolute;left:18px;top:0;width:36px;height:3px;background:linear-gradient(90deg, rgba(139,92,246,.52), rgba(139,92,246,0))}
.panel:hover{border-color:var(--line-strong);background:linear-gradient(180deg, rgba(210,214,220,.045), rgba(210,214,220,.028))}
.panel + .panel{margin-top:18px}
.panel-title{margin:0 0 6px;font-size:16px;color:var(--text-strong)}
.panel-copy{margin:0 0 16px;color:var(--muted)}
.panel-toolbar{display:flex;gap:16px;align-items:flex-start;justify-content:space-between;flex-wrap:wrap}
.panel-toolbar .panel-copy{margin-bottom:0;max-width:760px}
.panel-actions{display:flex;gap:10px;flex-wrap:wrap}
.panel-actions button,.modal-actions button:last-child,.logout-form button,.actions button{border-color:rgba(139,92,246,.4);background:linear-gradient(180deg, rgba(139,92,246,.085), rgba(210,214,220,.032))}
.table-wrap{width:100%;overflow-x:auto;margin-top:20px;-webkit-overflow-scrolling:touch;border:1px solid var(--line);border-radius:4px;background:linear-gradient(180deg, rgba(210,214,220,.04), rgba(210,214,220,.022));box-shadow:0 8px 16px rgba(0,0,0,.1)}
table{width:100%;border-collapse:collapse;min-width:640px}
th,td{padding:12px 14px;border-bottom:1px solid var(--line);text-align:left;vertical-align:top}
th{font-size:12px;letter-spacing:0;text-transform:uppercase;color:#979ca4;background:rgba(210,214,220,.042)}
tbody tr:last-child td{border-bottom:0}
tbody tr:hover td{background:rgba(210,214,220,.035)}
tbody tr:hover td:first-child{box-shadow:inset 2px 0 0 rgba(139,92,246,.62)}
.table-wrap button{padding:3px 7px;border-radius:3px;font-size:11px;box-shadow:none;background:rgba(210,214,220,.03);border-color:rgba(210,214,220,.075)}
.table-actions{display:flex;gap:6px;flex-wrap:wrap}
.inline-form{display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end}
.inline-form>*{flex:1 1 180px}
.inline-form .form-actions{flex:0 0 auto}
.field-group{display:flex;flex-direction:column;gap:6px;min-width:0}
.form-hint{margin:0;color:var(--muted);font-size:12px}
.mono{font-family:ui-monospace,SFMono-Regular,monospace}
.modal-dialog{width:min(680px,calc(100% - 24px));position:relative;overflow:hidden;padding:0;border:1px solid var(--line);border-radius:6px;background:linear-gradient(180deg, rgba(34,36,41,.98), rgba(24,26,30,.98));color:var(--text);box-shadow:0 18px 44px rgba(0,0,0,.3)}
.modal-dialog::before{content:"";position:absolute;left:18px;top:0;width:36px;height:1px;background:linear-gradient(90deg, rgba(139,92,246,.34), rgba(139,92,246,0))}
.modal-dialog::backdrop{background:rgba(12,13,16,.72)}
.modal-inner{padding:18px}
.modal-head{display:flex;gap:16px;align-items:flex-start;justify-content:space-between;margin-bottom:16px}
.modal-copy{margin:4px 0 0;color:var(--muted)}
.modal-close{width:36px;height:36px;display:inline-flex;align-items:center;justify-content:center;padding:0;border-radius:999px;background:rgba(210,214,220,.03);box-shadow:none;border:1px solid rgba(210,214,220,.075)}
.modal-form{display:grid;gap:14px}
.modal-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
.modal-actions{display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;margin-top:4px}
.brand-logo{width:32px;height:32px;display:block;flex:0 0 auto}
.nav{display:flex;gap:10px 14px;align-items:center;flex-wrap:wrap;margin:0 0 24px;padding:14px 16px;border:1px solid var(--line);border-radius:4px;background:rgba(24,26,30,.85);backdrop-filter:blur(10px);box-shadow:0 7px 16px rgba(0,0,0,.12);position:sticky;top:0;z-index:100}
.nav-brand{display:flex;align-items:center;gap:10px;min-width:0;text-decoration:none;color:var(--text);margin-right:6px}
.nav-brand-text{display:flex;flex-direction:column;gap:2px;min-width:0}
.nav-brand-title{font-size:13px;font-weight:700;letter-spacing:0;text-transform:uppercase;color:#c4c7ce}
.nav-links{display:flex;gap:10px 14px;align-items:center;flex-wrap:wrap}
.nav a{text-decoration:none;color:var(--text)}
.nav-link{padding:8px 12px;color:var(--muted);border-radius:4px;transition:background-color .18s ease,color .18s ease,box-shadow .18s ease}
.nav-link:hover{background:rgba(210,214,220,.035);color:var(--text)}
.nav-link.active{color:var(--text-strong);font-weight:600;background:rgba(210,214,220,.03);box-shadow:inset 0 -1px 0 rgba(139,92,246,.52)}
.nav-spacer{margin-left:auto}
.nav-user{color:var(--text-strong);min-width:0;overflow-wrap:anywhere}
.logout-form{margin:0}
.theme-toggle{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;padding:0;border-radius:999px}
.sun-icon{display:none}
.moon-icon{display:block}
[data-theme="light"] .sun-icon{display:block}
[data-theme="light"] .moon-icon{display:none}
[data-theme="dark"] .sun-icon{display:none}
.login-theme-toggle{position:absolute;top:12px;right:12px;display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;padding:0;border-radius:999px}
@media (max-width:520px){
.inline-form>*{flex:1 1 100%}
.inline-form .form-actions{flex:1 1 100%}
.modal-dialog{width:calc(100% - 16px)}
.modal-inner{padding:16px}
.modal-grid{grid-template-columns:1fr}
.nav{padding:12px}
.nav-link{padding:7px 10px}
}
[data-theme="light"] body{background:radial-gradient(circle at top,rgba(0,0,0,.015),transparent 22%),linear-gradient(180deg,#fff 0%,#f9fafb 44%,var(--bg) 100%)}
[data-theme="light"] body::before{background-image:linear-gradient(rgba(0,0,0,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,.03) 1px,transparent 1px);opacity:.5}
[data-theme="light"] select option{background:#fff;color:var(--text)}
[data-theme="light"] input::placeholder,[data-theme="light"] textarea::placeholder{color:#9ca3af}
[data-theme="light"] .nav{background:rgba(255,255,255,.88)}
[data-theme="light"] .nav-brand-title{color:#374151}
[data-theme="light"] th{color:#6b7280;background:var(--surface)}
[data-theme="light"] .modal-dialog{background:linear-gradient(180deg,rgba(255,255,255,.98),rgba(249,250,251,.98))}
[data-theme="light"] .modal-close{background:#f3f4f6;border-color:#e5e7eb}
[data-theme="light"] .table-wrap{background:linear-gradient(180deg,var(--card),var(--surface))}
[data-theme="light"] .flash{background:rgba(124,58,237,.04);border-color:rgba(124,58,237,.15)}
[data-theme="light"] .panel{background:linear-gradient(180deg,var(--card),var(--surface))}
[data-theme="light"] .panel:hover{background:linear-gradient(180deg,var(--card),rgba(249,250,251,.95))}
[data-theme="light"] tbody tr:hover td{background:var(--surface)}
[data-theme="light"] .ghost{background:var(--ghost);color:var(--muted);border-color:#e5e7eb}
[data-theme="light"] .ghost:hover{background:#e5e7eb;color:var(--text)}
[data-theme="light"] button:hover{border-color:rgba(124,58,237,.52);background:linear-gradient(180deg,rgba(124,58,237,.06),var(--ghost))}
[data-theme="light"] .panel-actions button,[data-theme="light"] .modal-actions button:last-child,[data-theme="light"] .logout-form button,[data-theme="light"] .actions button{border-color:rgba(124,58,237,.4);background:linear-gradient(180deg,rgba(124,58,237,.06),var(--ghost))}
[data-theme="light"] .table-wrap button{background:var(--ghost);border-color:#e5e7eb}
[data-theme="light"] input,[data-theme="light"] select,[data-theme="light"] textarea{background:#fff;box-shadow:inset 0 1px 0 rgba(0,0,0,.04)}
[data-theme="light"] input:focus,[data-theme="light"] select:focus,[data-theme="light"] textarea:focus{background:#fff}
[data-theme="light"] .login-card{background:linear-gradient(180deg,var(--card),var(--surface));border-color:var(--line)}
[data-theme="light"] .error{background:rgba(185,28,28,.05);color:#b91c1c}
[data-theme="light"] .nav-link.active{background:var(--surface);box-shadow:inset 0 -1px 0 rgba(124,58,237,.52)}
[data-theme="light"] .nav-user-btn{padding: 8px; background:var(--surface);border-color:var(--line)}
[data-theme="light"] .nav-user-btn:hover{background:var(--card);border-color:var(--line-strong);box-shadow:0 2px 6px rgba(0,0,0,.05)}
[data-theme="light"] .nav-user-btn svg{color:var(--muted)}
[data-theme="light"] .card{background:linear-gradient(180deg,var(--card),var(--surface))}
[data-theme="light"] section.card{background:linear-gradient(180deg,var(--card),var(--surface))}
[data-theme="light"] aside.card{background:linear-gradient(180deg,var(--surface),var(--card));box-shadow:none}
[data-theme="light"] .section{background:var(--surface);border-color:var(--line)}
[data-theme="light"] .section:hover{background:var(--card);border-color:var(--line-strong)}
[data-theme="light"] .result{background:#f9fafb;border-color:var(--line);box-shadow:inset 2px 0 0 rgba(124,58,237,.1),inset 0 1px 0 rgba(0,0,0,.04)}
[data-theme="light"] .metric{background:var(--surface);border-color:var(--line)}
[data-theme="light"] .error{background:rgba(185,28,28,.05);color:#b91c1c;border-color:rgba(185,28,28,.15)}
.nav-hamburger{display:none;align-items:center;justify-content:center;width:36px;height:36px;padding:0;border:0;background:none;color:var(--text-strong)}
.nav-hamburger:hover{background:rgba(210,214,220,.04);border-radius:6px}
.nav-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.5);opacity:0;visibility:hidden;transition:opacity .2s ease;pointer-events:none;z-index:998}
.nav-backdrop.open{opacity:1;visibility:visible;pointer-events:auto}
.nav-drawer{position:fixed;top:52px;width:100%;padding:0;border:0;border-radius:0;transform:translateY(-100%);transition:transform .2s ease;z-index:999;box-shadow:0 12px 28px rgba(0,0,0,.25);margin:0 auto;background:var(--bg);max-height:80dvh}
.nav-drawer[open]{transform:translateY(0)}
.nav-drawer::backdrop{background:rgba(0,0,0,.5)}
.nav-drawer-content{display:flex;flex-direction:column;padding:14px;height:auto;gap:6px;overflow-y:auto}
.nav-drawer-link{padding:12px 14px;border-radius:8px;color:var(--text-strong);text-decoration:none;font-weight:500;font-size:15px}
.nav-drawer-link:hover{background:rgba(210,214,220,.06)}
.nav-drawer-link.active{background:rgba(139,92,246,.1);color:var(--accent)}
.nav-drawer-divider{border:0;border-top:1px solid var(--line);margin:16px 0}
.nav-drawer-content .logout-form{margin-top:auto;padding-top:0}
.nav-drawer-content .logout-form button{width:100%;text-align:left}
.nav>.theme-toggle{margin-left:auto}
.nav-user-wrap{position:relative}
.nav-user-btn{display:inline-flex;align-items:center;gap:6px;padding:4px 6px 4px 4px;border:1px solid rgba(210,214,220,.06);background:rgba(210,214,220,.025);color:var(--text-strong);cursor:pointer;border-radius:6px;font-size:13px;transition:background-color .18s ease,border-color .18s ease,box-shadow .18s ease}
.nav-user-btn:hover{background:rgba(210,214,220,.045);border-color:rgba(210,214,220,.1);box-shadow:0 2px 6px rgba(0,0,0,.08)}
.nav-user-btn svg{width:18px;height:18px;color:var(--muted);flex-shrink:0;transition:color .18s ease}
.nav-user-btn:hover svg{color:var(--text-strong)}
.nav-user-dropdown{position:absolute;top:calc(100% + 6px);right:0;width:140px;padding:4px;background:var(--bg);border:1px solid var(--line);border-radius:6px;box-shadow:0 8px 16px rgba(0,0,0,.2);display:none;z-index:100}
.nav-user-dropdown.open{display:block}
.nav-user-dropdown .logout-form{margin:0}
.nav-user-dropdown button{width:100%;text-align:left;padding:8px 12px}
.nav>form.logout-form{display:none}
@media (max-width:720px){
body{padding:16px 4px}
.nav{flex-wrap:nowrap;padding:8px 4px;gap:8px;position:sticky;top:0;z-index:1000}
.nav-hamburger{display:flex}
.nav-links,.nav-spacer,.nav>form.logout-form{display:none}
.nav-user{display:block;flex-shrink:0;font-size:13px;color:var(--muted)}
.nav-drawer{left:4px;right:4px;width:auto;border-radius:8px;top:78px;transform:translateY(-120%)}
table{min-width:560px}
}

{{end}}
{{define "admin_theme_init"}}
<script>(function(){
var t=localStorage.getItem('theme');
if(!t){t='light';localStorage.setItem('theme',t);}
document.documentElement.setAttribute('data-theme',t);
})();</script>
{{end}}

{{define "admin_theme_toggle"}}
<script>(function(){
var b=document.getElementById('themeToggle');if(!b)return;
b.addEventListener('click',function(){
var n=document.documentElement.getAttribute('data-theme')==='light'?'dark':'light';
document.documentElement.setAttribute('data-theme',n);
localStorage.setItem('theme',n);
});
})();</script>
{{end}}

{{define "admin_dialog_helpers"}}
<script>
function openDialog(id){
  const dialog = document.getElementById(id);
  if(dialog && typeof dialog.showModal === 'function'){dialog.showModal();}
}

function closeDialog(id){
  const dialog = document.getElementById(id);
  if(dialog){dialog.close();}
}

document.querySelectorAll('dialog.modal-dialog').forEach(function(dialog){
  dialog.addEventListener('click', function(e){
    const rect = this.getBoundingClientRect();
    const inside = e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
    if(!inside){this.close();}
  });
});
</script>
{{end}}

{{define "admin_copy_helpers"}}
<script>
async function copyWithFallback(value){
  if (navigator.clipboard && window.isSecureContext) {
    await navigator.clipboard.writeText(value);
    return;
  }
  const textArea = document.createElement("textarea");
  textArea.value = value;
  textArea.setAttribute("readonly", "");
  textArea.style.position = "fixed";
  textArea.style.left = "-9999px";
  document.body.appendChild(textArea);
  textArea.select();
  const ok = document.execCommand("copy");
  document.body.removeChild(textArea);
  if (!ok) {
    throw new Error("copy failed");
  }
}
</script>
{{end}}

