<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>{{.Title}}</title>
<style>
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;max-width:1280px;margin:32px auto;padding:0 16px;color:#fffffe;background:#16161a}
nav a{margin-right:16px;color:#fffffe;text-decoration:none}
table{width:100%;border-collapse:collapse;margin-top:24px;background:rgba(255,255,255,.03)}
th,td{padding:10px;border-bottom:1px solid #72757e;text-align:left}
input{padding:10px;border:1px solid #72757e;border-radius:8px;margin-right:8px;min-width:140px;background:#fffffe;color:#010101}
button{padding:8px 12px;border:0;background:#7f5af0;color:#fffffe;border-radius:8px;cursor:pointer;font-weight:600}
.ghost{background:#72757e;color:#fffffe}
.muted{color:#94a1b2}
.flash{padding:10px 12px;background:#72757e;border-radius:8px;margin-top:16px;color:#fffffe}
.mono{font-family:ui-monospace,SFMono-Regular,monospace}
.sort-btn{background:none;border:0;color:#fffffe;padding:0;cursor:pointer;font:inherit}
.view-row{display:table-row}
.edit-row{display:none}
</style>
</head>
<body>
{{template "admin_nav" .}}
<h1>Providers</h1>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
<form method="post" action="/admin/providers" style="margin-top:20px">
  <input name="name" placeholder="name">
  <input name="base_url" placeholder="base url">
  <input name="anthropic_base_url" placeholder="anthropic base url (optional)">
  <input name="anthropic_version" placeholder="anthropic version (optional)">
  <input name="api_key" placeholder="api key (optional)">
  <input name="api_key_ref" placeholder="env var name (optional)">
  <input name="timeout" placeholder="timeout seconds" value="60">
  <button type="submit">Save</button>
</form>
<div class="muted" style="margin-top:8px">Fill either <span class="mono">api_key</span> or <span class="mono">api_key_ref</span>.</div>
<table id="providers-table">
  <thead>
    <tr>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',0,'text')">Name</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',1,'text')">Base URL</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',2,'text')">API Key</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',3,'text')">Anthropic URL</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',4,'text')">Anthropic Version</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',5,'text')">Secret Ref</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',6,'num')">Timeout</button></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{range .ProvidersCfg}}
    <tr class="view-row" data-name="{{.Name}}">
      <td>{{.Name}}</td>
      <td>{{.BaseURL}}</td>
      <td>{{if .APIKey}}configured{{else}}-{{end}}</td>
      <td>{{if .AnthropicBaseURL}}{{.AnthropicBaseURL}}{{else}}-{{end}}</td>
      <td>{{if .AnthropicVersion}}{{.AnthropicVersion}}{{else}}-{{end}}</td>
      <td>{{if .APIKeyRef}}{{.APIKeyRef}}{{else}}-{{end}}</td>
      <td>{{.TimeoutSeconds}}s</td>
      <td>
        <div style="display:flex;gap:8px">
          <button type="button" class="ghost" onclick="startEdit(this)">Edit</button>
          <form method="post" action="/admin/providers/delete" onsubmit="return confirmDeleteProvider()">
            <input type="hidden" name="name" value="{{.Name}}">
            <button type="submit">Delete</button>
          </form>
        </div>
      </td>
    </tr>
    <tr class="edit-row" data-name="{{.Name}}">
      <td colspan="8">
        <form method="post" action="/admin/providers" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap" onsubmit="this.querySelector('button[type=submit]').disabled=true">
          <input type="hidden" name="_method" value="PUT">
          <input type="hidden" name="name" value="{{.Name}}">
          <span class="mono" style="min-width:80px">{{.Name}}</span>
          <input name="base_url" value="{{.BaseURL}}" placeholder="base url">
          <input name="anthropic_base_url" value="{{.AnthropicBaseURL}}" placeholder="anthropic base url (optional)">
          <input name="anthropic_version" value="{{.AnthropicVersion}}" placeholder="anthropic version (optional)">
          <input name="api_key" placeholder="api key (optional)">
          <input name="api_key_ref" value="{{.APIKeyRef}}" placeholder="env var name (optional)">
          <input name="timeout" value="{{.TimeoutSeconds}}" placeholder="timeout" style="min-width:80px">
          <button type="submit">Save</button>
        </form>
        <button type="button" class="ghost" style="margin-left:8px" onclick="cancelEdit(this)">Cancel</button>
      </td>
    </tr>
    {{else}}
    <tr><td colspan="8" class="muted">No providers</td></tr>
    {{end}}
  </tbody>
</table>

<script>
function startEdit(btn){
  const row = btn.closest('.view-row');
  if(!row) return;
  const name = row.dataset.name;
  row.style.display = 'none';
  const editRow = row.nextElementSibling;
  if(editRow && editRow.classList.contains('edit-row') && editRow.dataset.name === name){
    editRow.style.display = 'table-row';
  }
}

function cancelEdit(btn){
  const row = btn.closest('.edit-row');
  if(!row) return;
  const name = row.dataset.name;
  row.style.display = 'none';
  const viewRow = row.previousElementSibling;
  if(viewRow && viewRow.classList.contains('view-row') && viewRow.dataset.name === name){
    viewRow.style.display = 'table-row';
  }
}

function sortTable(tableId, col, kind){
  const table = document.getElementById(tableId);
  if(!table || !table.tBodies || table.tBodies.length === 0){return;}
  const tbody = table.tBodies[0];
  // Sort pairs of view+edit rows together
  const pairs = [];
  for(let i = 0; i < tbody.rows.length; i += 2){
    const viewRow = tbody.rows[i];
    const editRow = tbody.rows[i + 1];
    pairs.push([viewRow, editRow || null]);
  }
  pairs.sort((a, b) => {
    const av = (a[0].cells[col]?.textContent || "").trim();
    const bv = (b[0].cells[col]?.textContent || "").trim();
    if(kind === "num"){
      const an = Number.parseInt(av, 10) || 0;
      const bn = Number.parseInt(bv, 10) || 0;
      return an - bn;
    }
    return av.localeCompare(bv);
  });
  for(const [vr, er] of pairs){
    tbody.appendChild(vr);
    if(er) tbody.appendChild(er);
  }
}

function confirmDeleteProvider(){
  return window.confirm("Delete this provider?");
}
</script>
</body>
</html>
