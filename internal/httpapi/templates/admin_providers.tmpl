<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>{{.Title}}</title>
<style>
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;max-width:1280px;margin:32px auto;padding:0 16px;color:#fffffe;background:#16161a}
nav a{margin-right:16px;color:#fffffe;text-decoration:none}
table{width:100%;border-collapse:collapse;margin-top:24px;background:rgba(255,255,255,.03)}
th,td{padding:10px;border-bottom:1px solid #72757e;text-align:left}
input{padding:10px;border:1px solid #72757e;border-radius:8px;margin-right:8px;min-width:140px;background:#fffffe;color:#010101}
button{padding:8px 12px;border:0;background:#7f5af0;color:#fffffe;border-radius:8px;cursor:pointer;font-weight:600}
.muted{color:#94a1b2}
.flash{padding:10px 12px;background:#72757e;border-radius:8px;margin-top:16px;color:#fffffe}
.mono{font-family:ui-monospace,SFMono-Regular,monospace}
.sort-btn{background:none;border:0;color:#fffffe;padding:0;cursor:pointer;font:inherit}
</style>
</head>
<body>
{{template "admin_nav" .}}
<h1>Providers</h1>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
<form method="post" action="/admin/providers" style="margin-top:20px">
  <input name="name" placeholder="name">
  <input name="base_url" placeholder="base url">
  <input name="api_key" placeholder="api key (optional)">
  <input name="api_key_ref" placeholder="env var name (optional)">
  <input name="timeout" placeholder="timeout seconds" value="60">
  <button type="submit">Save</button>
</form>
<div class="muted" style="margin-top:8px">Fill either <span class="mono">api_key</span> or <span class="mono">api_key_ref</span>.</div>
<table id="providers-table">
  <thead>
    <tr>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',0,'text')">Name</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',1,'text')">Base URL</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',2,'text')">API Key</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',3,'text')">Secret Ref</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',4,'num')">Timeout</button></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{range .ProvidersCfg}}
    <tr>
      <td>{{.Name}}</td>
      <td>{{.BaseURL}}</td>
      <td>{{if .APIKey}}configured{{else}}-{{end}}</td>
      <td>{{if .APIKeyRef}}{{.APIKeyRef}}{{else}}-{{end}}</td>
      <td>{{.TimeoutSeconds}}s</td>
      <td>
        <form method="post" action="/admin/providers/delete" onsubmit="return confirmDeleteProvider()">
          <input type="hidden" name="name" value="{{.Name}}">
          <button type="submit">Delete</button>
        </form>
      </td>
    </tr>
    {{else}}
    <tr><td colspan="6" class="muted">No providers</td></tr>
    {{end}}
  </tbody>
</table>
<script>
function sortTable(tableId, col, kind){
  const table = document.getElementById(tableId);
  if(!table || !table.tBodies || table.tBodies.length === 0){return;}
  const tbody = table.tBodies[0];
  const rows = Array.from(tbody.rows);
  if(rows.length === 0){return;}
  const nextAsc = table.dataset.sortCol !== String(col) ? true : table.dataset.sortAsc !== "true";
  rows.sort((a, b) => {
    const av = (a.cells[col]?.textContent || "").trim();
    const bv = (b.cells[col]?.textContent || "").trim();
    if(kind === "num"){
      const an = Number.parseInt(av, 10) || 0;
      const bn = Number.parseInt(bv, 10) || 0;
      return nextAsc ? an - bn : bn - an;
    }
    return nextAsc ? av.localeCompare(bv) : bv.localeCompare(av);
  });
  for(const row of rows){tbody.appendChild(row);}
  table.dataset.sortCol = String(col);
  table.dataset.sortAsc = nextAsc ? "true" : "false";
}

function confirmDeleteProvider(){
  return window.confirm("Delete this provider?");
}
</script>
</body>
</html>
