<!doctype html>
<html lang="{{.Lang}}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
{{template "admin_head_assets" .}}
{{template "admin_theme_init" .}}
<style>
{{template "admin_common_styles" .}}
.sort-btn{background:none;border:0;color:inherit;padding:0;cursor:pointer;font:inherit;transition:color .18s ease}
.sort-btn:hover{color:var(--text-strong)}
.providers-form{margin-top:20px}
.providers-form>*{flex:1 1 220px}
.row-actions{display:flex;gap:8px;flex-wrap:wrap}
.row-actions form{margin:0}
.row-actions button{transition:background-color .18s ease,border-color .18s ease,color .18s ease}
.provider-edit-form>*{flex:1 1 220px}
.providers-table{table-layout:fixed;min-width:0}
.providers-table th,.providers-table td{overflow-wrap:anywhere}
.providers-table tbody tr{transition:background-color .18s ease}
.providers-table th:nth-child(1){width:18%}
.providers-table td:nth-child(1){min-width:80px}
.providers-table th:nth-child(2){width:40%}
.providers-table td:nth-child(2){min-width:180px}
.providers-table th:nth-child(3){width:14%}
.providers-table td:nth-child(3){min-width:100px}
.providers-table th:nth-child(4){width:10%}
.providers-table td:nth-child(4){min-width:60px}
.providers-table th:nth-child(5){width:120px}
.providers-table td:nth-child(5){white-space:nowrap}
.connection-stack{display:flex;flex-direction:column;gap:6px;color:var(--text)}
.connection-badges{display:flex;gap:6px;flex-wrap:wrap}
.connection-stack .muted{font-size:12px}
@media(max-width:720px){
.providers-table{table-layout:auto}
.providers-table th,.providers-table td{font-size:13px;padding:10px 12px}
.providers-table th{white-space:nowrap}
.providers-table th:nth-child(1),.providers-table th:nth-child(2),.providers-table th:nth-child(3),.providers-table th:nth-child(4),.providers-table th:nth-child(5){width:auto}
}
</style>
</head>
<body><div class="page">
{{template "admin_nav" .}}
<h1>{{.T "Providers"}}</h1>
{{if .Flash}}<div class="flash">{{.T .Flash}}</div>{{end}}
<section class="panel">
<div class="panel-toolbar">
  <div>
    <h2 class="panel-title">{{.T "Provider Connections"}}</h2>
    <p class="panel-copy">{{.T "Configure upstream endpoints, credentials, and timeouts for each provider connection."}}</p>
  </div>
  <div class="panel-actions"><button type="button" onclick="openDialog('providerCreateDialog')">{{.T "New Provider"}}</button></div>
</div>
</section>
<div class="table-wrap"><table id="providers-table" class="providers-table">
  <thead>
    <tr>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',0,'text')">{{.T "Name"}}</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',1,'text')">{{.T "Connection"}}</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',2,'num')">{{.T "Timeout"}}</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',3,'text')">{{.T "Enabled"}}</button></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{range $i, $provider := .ProvidersCfg}}
    <tr data-name="{{$provider.Name}}">
      <td>{{$provider.Name}}</td>
      <td><div class="connection-stack">
        <div class="connection-badges">
          <span class="badge info">{{$.T "OpenAI"}}</span>
          {{if $provider.AnthropicBaseURL}}<span class="badge info">{{$.T "Anthropic"}}</span>{{end}}
          {{if and $provider.APIKey $provider.APIKeyRef}}<span class="badge warn">{{$.T "Key + env"}}</span>{{else if $provider.APIKey}}<span class="badge ok">{{$.T "Key"}}</span>{{else if $provider.APIKeyRef}}<span class="badge ok">{{$.T "Key env"}}</span>{{else}}<span class="badge off">{{$.T "Missing key"}}</span>{{end}}
        </div>
      </div></td>
      <td>{{$provider.TimeoutSeconds}}s</td>
      <td>{{if $provider.Enabled}}<span class="badge ok">{{$.T "Enabled"}}</span>{{else}}<span class="badge off">{{$.T "Disabled"}}</span>{{end}}</td>
      <td>
        <div class="table-actions">
          <button type="button" class="ghost" onclick="openDialog('providerEditDialog{{$i}}')">{{$.T "Edit"}}</button>
          <button type="button" class="danger" onclick="submitProviderDelete(this, '{{$provider.Name}}')">{{$.T "Delete"}}</button>
        </div>
      </td>
    </tr>
    {{else}}
    <tr><td colspan="5" class="muted">{{.T "No providers configured"}}</td></tr>
    {{end}}
  </tbody>
</table></div>
<dialog id="providerCreateDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">{{.T "New Provider"}}</h2>
        <p class="modal-copy">{{.T "Create an upstream provider configuration for routing and playground access."}}</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('providerCreateDialog')" aria-label="{{.T "Close"}}">×</button>
    </div>
    <form onsubmit="submitProviderCreate(this);return false" class="modal-form">
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-name">{{.T "Name"}}</label>
          <input id="provider-name" name="name" placeholder="{{.T "Provider name"}}">
        </div>
        <div class="field-group">
          <label for="provider-timeout">{{.T "Timeout"}}</label>
          <input id="provider-timeout" name="timeout" placeholder="{{.T "Timeout in seconds"}}" value="60">
        </div>
      </div>
      <div class="field-group">
        <label for="provider-base-url">Base URL</label>
        <input id="provider-base-url" name="base_url" placeholder="{{.T "Provider base URL"}}">
      </div>
      <label class="checkline"><input type="checkbox" name="enabled" checked>{{.T "Enabled"}}</label>
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-anthropic-base-url">Anthropic Base URL</label>
          <input id="provider-anthropic-base-url" name="anthropic_base_url" placeholder="{{.T "Anthropic base URL (optional)"}}">
        </div>
        <div class="field-group">
          <label for="provider-anthropic-version">Anthropic Version</label>
          <input id="provider-anthropic-version" name="anthropic_version" placeholder="{{.T "Anthropic version (optional)"}}">
        </div>
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-api-key">API Key</label>
          <input id="provider-api-key" name="api_key" placeholder="{{.T "Inline API key (optional)"}}">
        </div>
        <div class="field-group">
          <label for="provider-api-key-ref">Secret Ref</label>
          <input id="provider-api-key-ref" name="api_key_ref" placeholder="{{.T "Environment variable name (optional)"}}">
        </div>
      </div>
      <p class="form-hint">{{.T "Inline key takes precedence. Use env ref when you do not want to store the key here."}}</p>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('providerCreateDialog')">{{.T "Cancel"}}</button>
        <button type="submit">{{.T "Save"}}</button>
      </div>
    </form>
  </div>
</dialog>
{{range $i, $provider := .ProvidersCfg}}
<dialog id="providerEditDialog{{$i}}" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">{{$.T "Edit Provider"}}</h2>
        <p class="modal-copy">{{$.T "Update the endpoint, credentials, or timeout for "}}{{$provider.Name}}</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('providerEditDialog{{$i}}')" aria-label="{{$.T "Close"}}">×</button>
    </div>
    <form onsubmit="submitProviderUpdate(this, {{$i}});return false" class="modal-form provider-edit-form">
      <input type="hidden" name="name" value="{{$provider.Name}}">
      <input type="hidden" name="_enabled_present" value="1">
      <div class="modal-grid">
        <div class="field-group">
          <label>{{$.T "Name"}}</label>
          <input value="{{$provider.Name}}" disabled>
        </div>
        <div class="field-group">
          <label for="provider-timeout-{{$i}}">{{$.T "Timeout"}}</label>
          <input id="provider-timeout-{{$i}}" name="timeout" value="{{$provider.TimeoutSeconds}}" placeholder="{{$.T "Timeout in seconds"}}">
        </div>
      </div>
      <div class="field-group">
        <label for="provider-base-url-{{$i}}">Base URL</label>
        <input id="provider-base-url-{{$i}}" name="base_url" value="{{$provider.BaseURL}}" placeholder="{{$.T "Provider base URL"}}">
      </div>
      <label class="checkline"><input type="checkbox" name="enabled" value="true" {{if $provider.Enabled}}checked{{end}}>{{$.T "Enabled"}}</label>
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-anthropic-base-url-{{$i}}">Anthropic Base URL</label>
          <input id="provider-anthropic-base-url-{{$i}}" name="anthropic_base_url" value="{{$provider.AnthropicBaseURL}}" placeholder="{{$.T "Anthropic base URL (optional)"}}">
        </div>
        <div class="field-group">
          <label for="provider-anthropic-version-{{$i}}">Anthropic Version</label>
          <input id="provider-anthropic-version-{{$i}}" name="anthropic_version" value="{{$provider.AnthropicVersion}}" placeholder="{{$.T "Anthropic version (optional)"}}">
        </div>
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-api-key-{{$i}}">API Key</label>
          <input id="provider-api-key-{{$i}}" name="api_key" placeholder="{{$.T "Inline API key (optional)"}}">
        </div>
        <div class="field-group">
          <label for="provider-api-key-ref-{{$i}}">Secret Ref</label>
          <input id="provider-api-key-ref-{{$i}}" name="api_key_ref" value="{{$provider.APIKeyRef}}" placeholder="{{$.T "Environment variable name (optional)"}}">
        </div>
      </div>
      <p class="form-hint">{{$.T "Leave API Key blank to keep the current inline key. Inline key takes precedence over env ref."}}</p>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('providerEditDialog{{$i}}')">{{$.T "Cancel"}}</button>
        <button type="submit">{{$.T "Save"}}</button>
      </div>
    </form>
  </div>
</dialog>
{{end}}

{{template "admin_api_helpers" .}}
<script>
function openDialog(id){
  const dialog = document.getElementById(id);
  if(dialog && typeof dialog.showModal === 'function'){dialog.showModal();}
}

function closeDialog(id){
  const dialog = document.getElementById(id);
  if(dialog){dialog.close();}
}

function sortTable(tableId, col, kind){
  const table = document.getElementById(tableId);
  if(!table || !table.tBodies || table.tBodies.length === 0){return;}
  const tbody = table.tBodies[0];
  const rows = Array.from(tbody.rows);
  if(rows.length === 0){return;}
  const nextAsc = table.dataset.sortCol !== String(col) ? true : table.dataset.sortAsc !== "true";
  rows.sort((a, b) => {
    const av = (a.cells[col]?.textContent || "").trim();
    const bv = (b.cells[col]?.textContent || "").trim();
    if(kind === "num"){
      const an = Number.parseInt(av, 10) || 0;
      const bn = Number.parseInt(bv, 10) || 0;
      return nextAsc ? an - bn : bn - an;
    }
    return nextAsc ? av.localeCompare(bv) : bv.localeCompare(av);
  });
  for(const row of rows){tbody.appendChild(row);}
  table.dataset.sortCol = String(col);
  table.dataset.sortAsc = nextAsc ? "true" : "false";
}

function confirmDeleteProvider(name){
  return confirm({{toJSON (.T "Delete provider: ")}} + name + '?');
}

async function submitProviderCreate(form){
  const data = {
    name: form.querySelector('[name=name]').value,
    base_url: form.querySelector('[name=base_url]').value,
    timeout: parseInt(form.querySelector('[name=timeout]').value) || 60,
    anthropic_base_url: form.querySelector('[name=anthropic_base_url]').value,
    anthropic_version: form.querySelector('[name=anthropic_version]').value,
    api_key: form.querySelector('[name=api_key]').value,
    api_key_ref: form.querySelector('[name=api_key_ref]').value,
    enabled: form.querySelector('[name=enabled]').checked,
  };
  const result = await apiCall('POST', '/api/admin/providers', data);
  if (result && result.ok) {
    closeDialog('providerCreateDialog');
    reloadAfterToast({{toJSON (.T "Provider saved")}});
  }
}

async function submitProviderUpdate(form, idx){
  const name = form.querySelector('[name=name]').value;
  const data = {
    base_url: form.querySelector('[name=base_url]').value,
    timeout: parseInt(form.querySelector('[name=timeout]').value) || 60,
    anthropic_base_url: form.querySelector('[name=anthropic_base_url]').value,
    anthropic_version: form.querySelector('[name=anthropic_version]').value,
    api_key: form.querySelector('[name=api_key]').value,
    api_key_ref: form.querySelector('[name=api_key_ref]').value,
    enabled: form.querySelector('[name=enabled]').checked,
  };
  const result = await apiCall('PUT', '/api/admin/providers/' + encodeURIComponent(name), data);
  if (result && result.ok) {
    closeDialog('providerEditDialog'+idx);
    reloadAfterToast({{toJSON (.T "Provider updated")}});
  }
}

async function submitProviderDelete(btn, name){
  if(!confirm({{toJSON (.T "Delete provider: ")}} + name + '?')) return;
  const result = await apiCall('DELETE', '/api/admin/providers/' + encodeURIComponent(name));
  if (result && result.ok) {
    btn.closest('tr').remove();
    showToast({{toJSON (.T "Provider deleted")}});
  }
}

document.querySelectorAll('dialog.modal-dialog').forEach(function(dialog){
  dialog.addEventListener('click', function(e){
    const rect = this.getBoundingClientRect();
    const inside = e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
    if(!inside){this.close();}
  });
});
</script>
</div>{{template "admin_theme_toggle" .}}</body>
</html>
