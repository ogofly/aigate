<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
{{template "admin_head_assets" .}}
{{template "admin_theme_init" .}}
<style>
{{template "admin_common_styles" .}}
.sort-btn{background:none;border:0;color:inherit;padding:0;cursor:pointer;font:inherit;transition:color .18s ease}
.sort-btn:hover{color:var(--text-strong)}
.providers-form{margin-top:20px}
.providers-form>*{flex:1 1 220px}
.row-actions{display:flex;gap:8px;flex-wrap:wrap}
.row-actions form{margin:0}
.row-actions button{transition:background-color .18s ease,border-color .18s ease,color .18s ease}
.provider-edit-form>*{flex:1 1 220px}
.providers-table{table-layout:fixed;min-width:0}
.providers-table th,.providers-table td{overflow-wrap:anywhere}
.providers-table tbody tr{transition:background-color .18s ease}
.providers-table th:nth-child(1){width:15%}
.providers-table th:nth-child(2){width:29%}
.providers-table th:nth-child(3){width:23%}
.providers-table th:nth-child(4){width:15%}
.providers-table th:nth-child(5){width:8%}
.providers-table th:nth-child(6){width:10%}
</style>
</head>
<body><div class="page">
{{template "admin_nav" .}}
<h1>Providers</h1>
{{if .Flash}}<div class="flash">{{.Flash}}</div>{{end}}
<section class="panel">
<div class="panel-toolbar">
  <div>
    <h2 class="panel-title">Provider Connections</h2>
    <p class="panel-copy">Configure upstream endpoints, credentials, and timeouts for each provider connection.</p>
  </div>
  <div class="panel-actions"><button type="button" onclick="openDialog('providerCreateDialog')">New Provider</button></div>
</div>
</section>
<div class="table-wrap"><table id="providers-table" class="providers-table">
  <thead>
    <tr>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',0,'text')">Name</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',1,'text')">Base URL</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',2,'text')">Anthropic</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',3,'text')">Credentials</button></th>
      <th><button type="button" class="sort-btn" onclick="sortTable('providers-table',4,'num')">Timeout</button></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{range $i, $provider := .ProvidersCfg}}
    <tr data-name="{{$provider.Name}}">
      <td>{{$provider.Name}}</td>
      <td>{{$provider.BaseURL}}</td>
      <td>{{if $provider.AnthropicBaseURL}}{{$provider.AnthropicBaseURL}}{{if $provider.AnthropicVersion}}<br><span class="muted">{{$provider.AnthropicVersion}}</span>{{end}}{{else}}-{{end}}</td>
      <td>{{if $provider.APIKeyRef}}<span class="mono">{{$provider.APIKeyRef}}</span>{{else if $provider.APIKey}}configured{{else}}-{{end}}</td>
      <td>{{$provider.TimeoutSeconds}}s</td>
      <td>
        <div class="table-actions">
          <button type="button" class="ghost" onclick="openDialog('providerEditDialog{{$i}}')">Edit</button>
          <form method="post" action="/admin/providers/delete" onsubmit="return confirmDeleteProvider()">
            <input type="hidden" name="name" value="{{$provider.Name}}">
            <button type="submit">Delete</button>
          </form>
        </div>
      </td>
    </tr>
    {{else}}
    <tr><td colspan="6" class="muted">No providers configured</td></tr>
    {{end}}
  </tbody>
</table></div>
<dialog id="providerCreateDialog" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">New Provider</h2>
        <p class="modal-copy">Add an upstream provider configuration for routing and playground access.</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('providerCreateDialog')" aria-label="Close">×</button>
    </div>
    <form method="post" action="/admin/providers" class="modal-form">
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-name">Name</label>
          <input id="provider-name" name="name" placeholder="Provider name">
        </div>
        <div class="field-group">
          <label for="provider-timeout">Timeout</label>
          <input id="provider-timeout" name="timeout" placeholder="Timeout in seconds" value="60">
        </div>
      </div>
      <div class="field-group">
        <label for="provider-base-url">Base URL</label>
        <input id="provider-base-url" name="base_url" placeholder="Provider base URL">
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-anthropic-base-url">Anthropic Base URL</label>
          <input id="provider-anthropic-base-url" name="anthropic_base_url" placeholder="Anthropic base URL (optional)">
        </div>
        <div class="field-group">
          <label for="provider-anthropic-version">Anthropic Version</label>
          <input id="provider-anthropic-version" name="anthropic_version" placeholder="Anthropic version (optional)">
        </div>
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-api-key">API Key</label>
          <input id="provider-api-key" name="api_key" placeholder="Inline API key (optional)">
        </div>
        <div class="field-group">
          <label for="provider-api-key-ref">Secret Ref</label>
          <input id="provider-api-key-ref" name="api_key_ref" placeholder="Environment variable name (optional)">
        </div>
      </div>
      <p class="form-hint">Use an inline API key or a secret reference. Leave both empty only when the provider does not require credentials.</p>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('providerCreateDialog')">Cancel</button>
        <button type="submit">Save</button>
      </div>
    </form>
  </div>
</dialog>
{{range $i, $provider := .ProvidersCfg}}
<dialog id="providerEditDialog{{$i}}" class="modal-dialog">
  <div class="modal-inner">
    <div class="modal-head">
      <div>
        <h2 class="panel-title">Edit Provider</h2>
        <p class="modal-copy">Update the endpoint, credentials, or timeout for {{$provider.Name}}.</p>
      </div>
      <button type="button" class="modal-close ghost" onclick="closeDialog('providerEditDialog{{$i}}')" aria-label="Close">×</button>
    </div>
    <form method="post" action="/admin/providers" class="modal-form provider-edit-form" onsubmit="this.querySelector('button[type=submit]').disabled=true">
      <input type="hidden" name="_method" value="PUT">
      <input type="hidden" name="name" value="{{$provider.Name}}">
      <div class="modal-grid">
        <div class="field-group">
          <label>Name</label>
          <input value="{{$provider.Name}}" disabled>
        </div>
        <div class="field-group">
          <label for="provider-timeout-{{$i}}">Timeout</label>
          <input id="provider-timeout-{{$i}}" name="timeout" value="{{$provider.TimeoutSeconds}}" placeholder="Timeout in seconds">
        </div>
      </div>
      <div class="field-group">
        <label for="provider-base-url-{{$i}}">Base URL</label>
        <input id="provider-base-url-{{$i}}" name="base_url" value="{{$provider.BaseURL}}" placeholder="Provider base URL">
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-anthropic-base-url-{{$i}}">Anthropic Base URL</label>
          <input id="provider-anthropic-base-url-{{$i}}" name="anthropic_base_url" value="{{$provider.AnthropicBaseURL}}" placeholder="Anthropic base URL (optional)">
        </div>
        <div class="field-group">
          <label for="provider-anthropic-version-{{$i}}">Anthropic Version</label>
          <input id="provider-anthropic-version-{{$i}}" name="anthropic_version" value="{{$provider.AnthropicVersion}}" placeholder="Anthropic version (optional)">
        </div>
      </div>
      <div class="modal-grid">
        <div class="field-group">
          <label for="provider-api-key-{{$i}}">API Key</label>
          <input id="provider-api-key-{{$i}}" name="api_key" placeholder="Inline API key (optional)">
        </div>
        <div class="field-group">
          <label for="provider-api-key-ref-{{$i}}">Secret Ref</label>
          <input id="provider-api-key-ref-{{$i}}" name="api_key_ref" value="{{$provider.APIKeyRef}}" placeholder="Environment variable name (optional)">
        </div>
      </div>
      <p class="form-hint">Use an inline API key or a secret reference. Leave both empty only when the provider does not require credentials.</p>
      <div class="modal-actions">
        <button type="button" class="ghost" onclick="closeDialog('providerEditDialog{{$i}}')">Cancel</button>
        <button type="submit">Save</button>
      </div>
    </form>
  </div>
</dialog>
{{end}}

<script>
function openDialog(id){
  const dialog = document.getElementById(id);
  if(dialog && typeof dialog.showModal === 'function'){dialog.showModal();}
}

function closeDialog(id){
  const dialog = document.getElementById(id);
  if(dialog){dialog.close();}
}

function sortTable(tableId, col, kind){
  const table = document.getElementById(tableId);
  if(!table || !table.tBodies || table.tBodies.length === 0){return;}
  const tbody = table.tBodies[0];
  const rows = Array.from(tbody.rows);
  if(rows.length === 0){return;}
  const nextAsc = table.dataset.sortCol !== String(col) ? true : table.dataset.sortAsc !== "true";
  rows.sort((a, b) => {
    const av = (a.cells[col]?.textContent || "").trim();
    const bv = (b.cells[col]?.textContent || "").trim();
    if(kind === "num"){
      const an = Number.parseInt(av, 10) || 0;
      const bn = Number.parseInt(bv, 10) || 0;
      return nextAsc ? an - bn : bn - an;
    }
    return nextAsc ? av.localeCompare(bv) : bv.localeCompare(av);
  });
  for(const row of rows){tbody.appendChild(row);}
  table.dataset.sortCol = String(col);
  table.dataset.sortAsc = nextAsc ? "true" : "false";
}

function confirmDeleteProvider(){
  return window.confirm("Delete this provider?");
}

document.querySelectorAll('dialog.modal-dialog').forEach(function(dialog){
  dialog.addEventListener('click', function(e){
    const rect = this.getBoundingClientRect();
    const inside = e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
    if(!inside){this.close();}
  });
});
</script>
</div>{{template "admin_theme_toggle" .}}</body>
</html>
