<!doctype html>
<html lang="{{.Lang}}"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{.Title}}</title>{{template "admin_head_assets" .}}
{{template "admin_theme_init" .}}
<style>
{{template "admin_common_styles" .}}
.playground-page{padding-top:8px}
:root{--card:rgba(210,214,220,.035)}
[data-theme="light"]{--card:#fefefe}
button:disabled{opacity:0.5;cursor:not-allowed}
.grid{display:grid;grid-template-columns:1.1fr .9fr;gap:16px}
.grid>*{min-width:0}
.card{position:relative;min-width:0;background:linear-gradient(180deg, rgba(210,214,220,.038), rgba(210,214,220,.022));border:1px solid var(--line);border-radius:8px;padding:18px;box-shadow:0 8px 18px rgba(0,0,0,.1);transition:border-color .18s ease,background-color .18s ease}
.card::before{content:"";position:absolute;left:18px;top:0;width:36px;height:1px;background:linear-gradient(90deg, rgba(139,92,246,.42), rgba(139,92,246,0))}
section.card{background:linear-gradient(180deg, rgba(210,214,220,.045), rgba(210,214,220,.026))}
aside.card{background:linear-gradient(180deg, rgba(210,214,220,.028), rgba(210,214,220,.018));box-shadow:none}
.card:hover{border-color:var(--line-strong)}
.title{font-size:20px;margin:0 0 6px}
.subtle-copy{margin:0 0 16px}
.row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px}
.stack{display:grid;gap:10px}
.section{padding:14px;border:1px solid rgba(210,214,220,.075);border-radius:8px;background:rgba(210,214,220,.022);transition:border-color .18s ease,background-color .18s ease}
.section:hover{border-color:rgba(210,214,220,.11);background:rgba(210,214,220,.028)}
textarea{min-height:64px;resize:vertical}
.actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.hint{font-size:12px;color:var(--muted)}
.hint[href]{text-decoration:none}
.hint-row{display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:10px}
.result{margin-top:12px;width:100%;max-width:100%;min-width:0;border:1px solid rgba(210,214,220,.08);border-radius:10px;background:rgba(22,24,28,.8);padding:14px 16px;white-space:pre-wrap;overflow-wrap:anywhere;word-break:break-word;max-height:420px;overflow:auto;overscroll-behavior:contain;box-shadow:inset 2px 0 0 rgba(139,92,246,.14),inset 0 1px 0 rgba(210,214,220,.022)}
.loading{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--muted)}
.loading::before{content:'';width:14px;height:14px;border:2px solid var(--muted);border-top-color:#8b5cf6;border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.view-toggle{display:flex;gap:4px;align-items:center;margin-bottom:8px}
.view-toggle button{font-size:11px;padding:2px 8px;border:1px solid rgba(210,214,220,.15);border-radius:4px;background:transparent;color:var(--muted);cursor:pointer;transition:all .15s ease}
.view-toggle button.active{background:rgba(139,92,246,.18);color:var(--text);border-color:rgba(139,92,246,.35)}
.view-toggle button:hover:not(.active){background:rgba(210,214,220,.05)}
.result-title{display:block;margin-bottom:8px;font-size:12px;letter-spacing:0;text-transform:uppercase;color:var(--muted)}
.request-preview{margin-top:12px}
.request-preview pre{margin:8px 0 0;max-height:260px;overflow:auto;white-space:pre-wrap;overflow-wrap:anywhere}
.error{margin-top:12px;padding:12px 14px;border-radius:10px;background:rgba(120,42,42,.1);color:#d2a0a0;border:1px solid rgba(180,80,80,.22)}
.kv{display:grid;grid-template-columns:98px minmax(0,1fr) auto;gap:10px;align-items:center;margin-bottom:10px}
.mono{font-size:13px;word-break:break-all}
.hidden{display:none}
.radio-group{display:flex;gap:16px;flex-wrap:wrap}
.radio-group label{display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;color:var(--text)}
.radio-group input{width:auto}
.field-label{font-size:13px;color:var(--muted);margin-bottom:6px}
.metric{padding:12px 14px;border-radius:8px;border:1px solid rgba(210,214,220,.075);background:rgba(210,214,220,.022)}
.metric-label{font-size:12px;color:var(--muted);letter-spacing:0;text-transform:uppercase}
.metric-value{margin-top:6px;font-size:13px;overflow-wrap:anywhere}
aside .hint{margin-top:12px;display:block}
.request-preview-head{display:flex;align-items:center;justify-content:space-between;gap:10px}
.request-preview-head button{padding:5px 10px;font-size:12px}
@media (max-width:900px){.grid{grid-template-columns:1fr}.row{grid-template-columns:1fr}}
@media (max-width:640px){
.card{padding:14px}
.section{padding:12px}
.kv{grid-template-columns:1fr}
.kv button{width:100%}
.actions button,.actions a{width:100%;text-align:center}
.hint-row{align-items:flex-start;flex-direction:column}
textarea{min-height:64px}
}
</style>
</head><body><div class="page playground-page">
{{template "admin_nav" .}}
<div id="apiBaseData" class="hidden">{{.PlayAPIBase}}</div>
<div class="grid">
<section class="card">
<h1 class="title">{{.T "Playground"}}</h1>
<p class="muted subtle-copy">{{.T "Send a quick test request with a managed key to verify auth, routing, and endpoint behavior."}}</p>
<form id="playgroundForm">
<div class="row">
<div><label>{{.T "API Key"}}</label><select name="api_key" id="apiKey">{{range .Keys}}<option value="{{.Key}}" data-mask="{{maskID .Key}}" {{if eq $.PlayAPIKey .Key}}selected{{end}}>{{if .Name}}{{.Name}}{{else}}(unnamed){{end}} / {{maskID .Key}}</option>{{end}}</select></div>
<div><label>{{.T "Model"}}</label><select name="model" id="model">{{range .PlayModels}}<option value="{{.}}" {{if eq $.PlayModel .}}selected{{end}}>{{.}}</option>{{end}}</select></div>
<div><label>{{.T "Provider"}}</label><select name="provider" id="provider"><option value="">{{.T "Default route"}}</option></select><div class="hint" id="providerHint">{{.T "Default route strategy"}}</div></div>
</div>

<div id="playgroundMain" style="display:none">
<div class="stack">
<div class="section">
<div class="field-label">{{.T "API Style"}}</div>
<div class="radio-group">
<label><input type="radio" name="api_style" value="openai" {{if not .PlayUseAnthropic}}checked{{end}}> OpenAI</label>
<label><input type="radio" name="api_style" value="anthropic" {{if .PlayUseAnthropic}}checked{{end}}> Anthropic</label>
</div>
</div>

<div id="openaiSub" class="section" style="{{if .PlayUseAnthropic}}display:none{{end}}">
<div class="field-label">{{.T "OpenAI Endpoint"}}</div>
<div class="radio-group">
<label><input type="radio" name="api_type" value="chat_completions" {{if not .PlayUseResponses}}checked{{end}}>{{.T "Chat Completions"}}</label>
<label><input type="radio" name="api_type" value="responses" {{if .PlayUseResponses}}checked{{end}}>{{.T "Responses"}}</label>
</div>
</div>

<div class="section">
<label style="display:flex;align-items:center;gap:8px"><input type="checkbox" name="stream" id="stream" {{if .PlayStream}}checked{{end}} style="width:auto">{{.T "Stream"}}</label>
</div>

<div>
<label>{{.T "Message"}}</label>
<textarea name="message" id="message" placeholder="{{.T "Say something..."}}">{{.PlayMessage}}</textarea>
<div class="hint-row">
<span class="hint">{{.T "Use this view for fast request checks before wiring a client application."}}</span>
<span id="loadingHint" class="loading" style="display:none">{{.T "Sending request..."}}</span>
</div>
</div>
<div class="actions"><button type="submit" id="sendBtn">{{.T "Send"}}</button><a class="hint" href="/admin/playground">{{.T "Clear"}}</a></div>
</div>
</div>
</form>
{{if .PlayError}}<div class="error">{{.PlayError}}</div>{{end}}
<div id="errorDiv" class="error" style="display:none"></div>
<div id="resultWrap" style="display:none">
<div class="view-toggle" id="viewToggle" style="display:none">
<button id="parsedBtn" class="active" onclick="setView('parsed')">{{.T "Parsed"}}</button>
<button id="rawBtn" onclick="setView('raw')">{{.T "Raw SSE"}}</button>
</div>
<div id="resultDiv" class="result"></div>
</div>
{{if .PlayResult}}<div class="result"><span class="result-title">{{.T "Reply"}}</span>{{.PlayResult}}</div>{{end}}
</section>
<aside class="card">
<h2 class="title">{{.T "Connection Details"}}</h2>
<p class="muted subtle-copy" id="modeHint">{{.T "OpenAI Chat Completions settings for your client."}}</p>
<div id="connectKv" style="display:none" class="stack">
<div class="kv"><div class="muted">{{.T "API Base URL"}}</div><div class="mono" id="cfgBase">{{.PlayAPIBase}}/v1</div><button type="button" class="ghost" onclick="copyText('cfgBase', this)">{{.T "Copy"}}</button></div>
<div class="kv"><div class="muted">{{.T "API Key"}}</div><div class="mono" id="cfgKey" data-copy="{{.PlayAPIKey}}">{{maskID .PlayAPIKey}}</div><button type="button" class="ghost" onclick="copyText('cfgKey', this)">{{.T "Copy"}}</button></div>
<div class="kv"><div class="muted">{{.T "Model"}}</div><div class="mono" id="cfgModel">{{.PlayModel}}</div><button type="button" class="ghost" onclick="copyText('cfgModel', this)">{{.T "Copy"}}</button></div>
<div class="kv"><div class="muted">{{.T "Provider"}}</div><div class="mono" id="cfgProvider">{{.T "Default route"}}</div><button type="button" class="ghost" onclick="copyText('cfgProvider', this)">{{.T "Copy"}}</button></div>
<div class="metric">
<div class="metric-label">{{.T "Request Path"}}</div>
<div class="metric-value">{{.T "Requests from this page use the same auth, routing, and upstream path as the public API."}}</div>
</div>
<div class="metric request-preview">
<div class="request-preview-head"><div class="metric-label">{{.T "Request Preview"}}</div><button type="button" class="ghost" onclick="copyCurl(this)">{{.T "Copy curl"}}</button></div>
<pre class="metric-value mono" id="requestPreview" data-copy=""></pre>
</div>
</div>
<div class="hint" id="endpointHint">{{.T "Endpoint"}}: <span class="mono">/chat/completions</span></div>
</aside>
</div>
</div>
<script>
async function copyText(id, button){
	const el = document.getElementById(id);
	if(!el){return;}
	try{
		await copyWithFallback(el.dataset.copy || el.textContent || "");
		const origin = button.textContent;
		button.textContent = {{toJSON (.T "Copied")}};
		setTimeout(()=>{button.textContent = origin;}, 1000);
	}catch(_e){
		button.textContent = {{toJSON (.T "Failed")}};
		setTimeout(()=>{button.textContent = {{toJSON (.T "Copy")}};}, 1000);
	}
}

async function copyWithFallback(value){
	if (navigator.clipboard && window.isSecureContext) {
		await navigator.clipboard.writeText(value);
		return;
	}
	const textArea = document.createElement("textarea");
	textArea.value = value;
	textArea.setAttribute("readonly", "");
	textArea.style.position = "fixed";
	textArea.style.left = "-9999px";
	document.body.appendChild(textArea);
	textArea.select();
	const ok = document.execCommand("copy");
	document.body.removeChild(textArea);
	if (!ok) {
		throw new Error("copy failed");
	}
}

const form = document.getElementById('playgroundForm');
const sendBtn = document.getElementById('sendBtn');
const loadingHint = document.getElementById('loadingHint');
const resultDiv = document.getElementById('resultDiv');
const resultWrap = document.getElementById('resultWrap');
const errorDiv = document.getElementById('errorDiv');
const viewToggle = document.getElementById('viewToggle');
const parsedBtn = document.getElementById('parsedBtn');
const rawBtn = document.getElementById('rawBtn');
const modeHint = document.getElementById('modeHint');
const cfgBase = document.getElementById('cfgBase');
const cfgKey = document.getElementById('cfgKey');
const cfgModel = document.getElementById('cfgModel');
const cfgProvider = document.getElementById('cfgProvider');
const endpointHint = document.getElementById('endpointHint');
const openaiSub = document.getElementById('openaiSub');
const playgroundMain = document.getElementById('playgroundMain');
const connectKv = document.getElementById('connectKv');
const apiKeySelect = document.getElementById('apiKey');
const modelSelect = document.getElementById('model');
const providerSelect = document.getElementById('provider');
const providerHint = document.getElementById('providerHint');
const requestPreview = document.getElementById('requestPreview');
const apiBaseEl = document.getElementById('apiBaseData');
const apiBase = apiBaseEl ? apiBaseEl.textContent : '';
const providerOptions = {{toJSON .PlayModelProviders}};

let currentView = 'parsed';
let parsedText = '';
let rawLines = '';
let streamComplete = false;
let abortController = null;

function setView(view) {
	currentView = view;
	parsedBtn.className = view === 'parsed' ? 'active' : '';
	rawBtn.className = view === 'raw' ? 'active' : '';
	const display = view === 'parsed' ? (parsedText || '') : rawLines;
	resultDiv.textContent = display || (streamComplete ? '' : '');
	resultDiv.scrollTop = resultDiv.scrollHeight;
}

function resetResult() {
	parsedText = '';
	rawLines = '';
	streamComplete = false;
	resultDiv.textContent = '';
	viewToggle.style.display = 'none';
}

function appendParsed(text) {
	parsedText += text;
	if (currentView === 'parsed') {
		resultDiv.textContent = parsedText;
		resultDiv.scrollTop = resultDiv.scrollHeight;
	}
}

function appendRaw(line) {
	rawLines += line + '\n';
	if (currentView === 'raw') {
		resultDiv.textContent = rawLines;
		resultDiv.scrollTop = resultDiv.scrollHeight;
	}
}

function getApiStyle(){ return document.querySelector('input[name="api_style"]:checked')?.value || 'openai'; }
function getApiType(){ return document.querySelector('input[name="api_type"]:checked')?.value || 'chat_completions'; }

function apiPath(){
	const style = getApiStyle();
	const apiType = getApiType();
	if (style === 'anthropic') return '/anthropic/v1/messages';
	if (apiType === 'responses') return '/v1/responses';
	return '/v1/chat/completions';
}

function requestBody(isStream){
	const model = modelSelect.value;
	const message = document.getElementById('message').value;
	const style = getApiStyle();
	const apiType = getApiType();
	let body;
	if (style === 'anthropic') {
		body = {model:model,messages:[{role:'user',content:message}],max_tokens:4096};
	} else if (apiType === 'responses') {
		body = {model:model,input:message};
	} else {
		body = {model:model,messages:[{role:'user',content:message}]};
	}
	if (isStream) {
		body.stream = true;
	}
	return body;
}

function requestHeaders(){
	const headers = {
		'Authorization':'Bearer ' + apiKeySelect.value,
		'Content-Type':'application/json',
	};
	if (providerSelect.value) {
		headers['X-Provider'] = providerSelect.value;
	}
	return headers;
}

function shellQuote(value){
	return "'" + String(value).replace(/'/g, "'\"'\"'") + "'";
}

function curlCommand(maskSecret){
	const headers = requestHeaders();
	const selectedKey = apiKeySelect.options[apiKeySelect.selectedIndex];
	const authValue = maskSecret ? (selectedKey?.dataset.mask || '') : apiKeySelect.value;
	const lines = [
		'curl -X POST ' + shellQuote(apiBase + apiPath()),
		'  -H ' + shellQuote('Authorization: Bearer ' + authValue),
		'  -H ' + shellQuote('Content-Type: application/json'),
	];
	if (headers['X-Provider']) {
		lines.push('  -H ' + shellQuote('X-Provider: ' + headers['X-Provider']));
	}
	lines.push('  -d ' + shellQuote(JSON.stringify(requestBody(document.getElementById('stream').checked), null, 2)));
	return lines.join(' \\\n');
}

function updateRequestPreview(){
	if(!requestPreview){return;}
	requestPreview.textContent = curlCommand(true);
	requestPreview.dataset.copy = curlCommand(false);
}

async function copyCurl(button){
	if(!requestPreview){return;}
	try{
		await copyWithFallback(requestPreview.dataset.copy || requestPreview.textContent || "");
		const origin = button.textContent;
		button.textContent = {{toJSON (.T "Copied")}};
		setTimeout(()=>{button.textContent = origin;}, 1000);
	}catch(_e){
		button.textContent = {{toJSON (.T "Failed")}};
		setTimeout(()=>{button.textContent = {{toJSON (.T "Copy curl")}};}, 1000);
	}
}

function updateModeUI(){
	const style = getApiStyle();
	const apiType = getApiType();

	openaiSub.style.display = style === 'openai' ? '' : 'none';

	if (style === 'anthropic') {
		modeHint.textContent = {{toJSON (.T "Anthropic Messages settings for your client.")}};
		cfgBase.textContent = apiBase + '/anthropic';
		endpointHint.innerHTML = {{toJSON (.T "Endpoint")}} + ': <span class="mono">/messages</span>';
	} else if (apiType === 'responses') {
		modeHint.textContent = {{toJSON (.T "OpenAI Responses settings for your client.")}};
		cfgBase.textContent = apiBase + '/v1';
		endpointHint.innerHTML = {{toJSON (.T "Endpoint")}} + ': <span class="mono">/responses</span>';
	} else {
		modeHint.textContent = {{toJSON (.T "OpenAI Chat Completions settings for your client.")}};
		cfgBase.textContent = apiBase + '/v1';
		endpointHint.innerHTML = {{toJSON (.T "Endpoint")}} + ': <span class="mono">/chat/completions</span>';
	}
	updateRequestPreview();
}

document.querySelectorAll('input[name="api_style"]').forEach(r => r.addEventListener('change', updateModeUI));
document.querySelectorAll('input[name="api_type"]').forEach(r => r.addEventListener('change', updateModeUI));

function toggleMain(){
	const hasKey = apiKeySelect.value !== '';
	playgroundMain.style.display = hasKey ? '' : 'none';
	connectKv.style.display = hasKey ? '' : 'none';
}

function updateConnectionValues(){
	const selectedKey = apiKeySelect.options[apiKeySelect.selectedIndex];
	cfgKey.textContent = selectedKey ? selectedKey.dataset.mask || '' : '';
	cfgKey.dataset.copy = apiKeySelect.value;
	cfgModel.textContent = modelSelect.value;
	const providerText = providerSelect.value || {{toJSON (.T "Default route")}};
	cfgProvider.textContent = providerText;
	cfgProvider.dataset.copy = providerSelect.value;
	providerHint.textContent = providerSelect.value ? {{toJSON (.T "Adds X-Provider; failover stays within provider.")}} : {{toJSON (.T "Default route strategy")}};
	updateRequestPreview();
}

function updateProviderOptions(){
	const current = providerSelect.value;
	const byKey = providerOptions[apiKeySelect.value] || {};
	const providers = byKey[modelSelect.value] || [];
	providerSelect.innerHTML = '';
	const defaultOption = document.createElement('option');
	defaultOption.value = '';
	defaultOption.textContent = {{toJSON (.T "Default route")}};
	providerSelect.appendChild(defaultOption);
	for (const provider of providers) {
		const option = document.createElement('option');
		option.value = provider;
		option.textContent = provider;
		providerSelect.appendChild(option);
	}
	providerSelect.value = providers.includes(current) ? current : '';
	providerSelect.disabled = providers.length === 0;
}

apiKeySelect.addEventListener('change', () => {
	toggleMain();
	updateProviderOptions();
	updateConnectionValues();
	updateModeUI();
});

modelSelect.addEventListener('change', () => {
	updateProviderOptions();
	updateConnectionValues();
});
providerSelect.addEventListener('change', updateConnectionValues);
document.getElementById('message').addEventListener('input', updateRequestPreview);
document.getElementById('stream').addEventListener('change', updateRequestPreview);

form.addEventListener('submit', async (e) => {
	e.preventDefault();
	if (abortController) { abortController.abort(); abortController = null; }
	const isStream = document.getElementById('stream').checked;
	sendBtn.disabled = true;
	loadingHint.style.display = 'inline-flex';
	errorDiv.style.display = 'none';
	resultWrap.style.display = 'block';
	resetResult();

	try {
		if (isStream) {
			await handleStream();
		} else {
			await handleNonStream();
		}
	} catch (err) {
		errorDiv.textContent = err.message;
		errorDiv.style.display = 'block';
	} finally {
		sendBtn.disabled = false;
		loadingHint.style.display = 'none';
	}
});

async function handleStream() {
	abortController = new AbortController();
	let resp;
	try {
		resp = await fetch(apiPath(), {
			method: 'POST',
			headers: requestHeaders(),
			body: JSON.stringify(requestBody(true)),
			signal: abortController.signal,
		});
	} catch (e) {
		if (e.name !== 'AbortError') throw e;
		return;
	}
	if (!resp.ok) {
		const message = await readError(resp);
		errorDiv.textContent = message || {{toJSON (.T "Request failed")}};
		errorDiv.style.display = 'block';
		return;
	}

	viewToggle.style.display = 'flex';
	currentView = 'parsed';
	parsedBtn.className = 'active';
	rawBtn.className = '';

	const reader = resp.body.getReader();
	const decoder = new TextDecoder();
	let buffer = '';
	let currentEvent = '';

	while (true) {
		let chunk;
		try {
			chunk = await reader.read();
		} catch (e) {
			if (e.name === 'AbortError') return;
			throw e;
		}
		const { done, value } = chunk;
		if (done) break;
		buffer += decoder.decode(value, { stream: true });
		const lines = buffer.split('\n');
		buffer = lines.pop() || '';

		for (const line of lines) {
			const trimmed = line.replace(/\r$/, '');
			if (!trimmed) continue;
			appendRaw(trimmed);

			if (trimmed.startsWith('event: ')) {
				currentEvent = trimmed.slice(7).trim();
			} else if (trimmed.startsWith('data: ')) {
				const payload = trimmed.slice(6);
				if (payload === '[DONE]') {
					currentEvent = '';
					continue;
				}
				try {
					const d = JSON.parse(payload);
					if (currentEvent === 'error' || d.error) {
						errorDiv.textContent = streamErrorMessage(d);
						errorDiv.style.display = 'block';
						abortController.abort();
						return;
					}
					const text = extractStreamText(d);
					if (text) appendParsed(text);
				} catch (_e) {}
				currentEvent = '';
			}
		}
	}

	// Show completion indicator.
	streamComplete = true;
	const marker = '\n\n--- Stream complete ---';
	parsedText += marker;
	rawLines += '\n--- Stream complete ---\n';
	if (currentView === 'parsed') {
		resultDiv.textContent = parsedText;
	} else {
		resultDiv.textContent = rawLines;
	}
	resultDiv.scrollTop = resultDiv.scrollHeight;
}

async function handleNonStream() {
	const resp = await fetch(apiPath(), {
		method: 'POST',
		headers: requestHeaders(),
		body: JSON.stringify(requestBody(false)),
	});
	const data = await resp.json().catch(() => null);
	if (!resp.ok) { throw new Error(errorMessage(data) || {{toJSON (.T "Request failed")}}); }
	parsedText = extractResponseText(data) || JSON.stringify(data, null, 2);
	viewToggle.style.display = 'flex';
	resultDiv.textContent = parsedText;
}

async function readError(resp){
	const data = await resp.json().catch(() => null);
	if (data) return errorMessage(data);
	return await resp.text().catch(() => '');
}

function errorMessage(data){
	if(!data) return '';
	if(typeof data.error === 'string') return data.error;
	if(data.error && typeof data.error.message === 'string') return data.error.message;
	if(typeof data.message === 'string') return data.message;
	return '';
}

function streamErrorMessage(data){
	return errorMessage(data) || {{toJSON (.T "Stream error")}};
}

function extractResponseText(data){
	if(!data) return '';
	if(getApiStyle() === 'anthropic'){
		const parts = Array.isArray(data.content) ? data.content : [];
		return parts.map(function(part){return part && part.type === 'text' ? part.text || '' : '';}).join('\n').trim();
	}
	if(getApiType() === 'responses'){
		const output = Array.isArray(data.output) ? data.output : [];
		const texts = [];
		for(const item of output){
			const content = Array.isArray(item && item.content) ? item.content : [];
			for(const part of content){
				if(part && part.type === 'output_text' && typeof part.text === 'string') texts.push(part.text);
			}
		}
		return texts.join('');
	}
	const choices = Array.isArray(data.choices) ? data.choices : [];
	return choices[0]?.message?.content || '';
}

function extractStreamText(data){
	if(getApiStyle() === 'anthropic'){
		if(data.type === 'content_block_delta' && data.delta && typeof data.delta.text === 'string') return data.delta.text;
		return '';
	}
	if(getApiType() === 'responses'){
		if(data.type === 'response.output_text.delta' && typeof data.delta === 'string') return data.delta;
		return '';
	}
	const choices = Array.isArray(data.choices) ? data.choices : [];
	return choices[0]?.delta?.content || '';
}

toggleMain();
updateProviderOptions();
updateConnectionValues();
updateModeUI();
</script>
</body>{{template "admin_theme_toggle" .}}</html>
