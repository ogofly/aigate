<!doctype html>
<html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{.Title}}</title>
<style>
{{template "admin_common_styles" .}}
.playground-page{padding-top:8px}
:root{--card:rgba(22,16,40,.72)}
button:disabled{opacity:0.5;cursor:not-allowed}
.grid{display:grid;grid-template-columns:1.1fr .9fr;gap:16px}
.grid>*{min-width:0}
.card{min-width:0;background:linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.025));border:1px solid var(--line);border-radius:22px;padding:18px;box-shadow:var(--shadow);backdrop-filter:blur(8px)}
.title{font-size:20px;margin:0 0 6px}
.subtle-copy{margin:0 0 16px}
.row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.stack{display:grid;gap:12px}
.section{padding:14px;border:1px solid rgba(255,255,255,.08);border-radius:16px;background:rgba(255,255,255,.025)}
textarea{min-height:180px;resize:vertical}
.actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.hint{font-size:12px;color:var(--muted)}
.hint[href]{text-decoration:none}
.hint-row{display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:10px}
.result{margin-top:12px;width:100%;max-width:100%;min-width:0;border:1px solid rgba(139,92,246,.16);border-radius:16px;background:rgba(11,8,22,.82);padding:14px 16px;white-space:pre-wrap;overflow-wrap:anywhere;word-break:break-word;max-height:420px;overflow:auto;overscroll-behavior:contain;box-shadow:inset 0 1px 0 rgba(255,255,255,.04)}
.result-title{display:block;margin-bottom:8px;font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted)}
.error{margin-top:12px;padding:12px 14px;border-radius:16px;background:#fff2f2;color:#9f2d2d;border:1px solid #ffd1d1}
.kv{display:grid;grid-template-columns:110px minmax(0,1fr) auto;gap:10px;align-items:center;margin-bottom:10px}
.mono{font-size:13px;word-break:break-all}
.hidden{display:none}
.radio-group{display:flex;gap:16px;flex-wrap:wrap}
.radio-group label{display:flex;align-items:center;gap:6px;cursor:pointer;font-size:14px}
.radio-group input{width:auto}
.field-label{font-size:13px;color:var(--muted);margin-bottom:6px}
.metric{padding:12px 14px;border-radius:16px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.025)}
.metric-label{font-size:12px;color:var(--muted);letter-spacing:.04em;text-transform:uppercase}
.metric-value{margin-top:6px;font-size:13px;overflow-wrap:anywhere}
aside .hint{margin-top:12px;display:block}
@media (max-width:900px){.grid{grid-template-columns:1fr}.row{grid-template-columns:1fr}}
@media (max-width:640px){
.card{padding:14px}
.section{padding:12px}
.kv{grid-template-columns:1fr}
.kv button{width:100%}
.actions button,.actions a{width:100%;text-align:center}
.hint-row{align-items:flex-start;flex-direction:column}
textarea{min-height:140px}
}
</style>
</head><body><div class="page playground-page">
{{template "admin_nav" .}}
<div id="apiBaseData" class="hidden">{{.PlayAPIBase}}</div>
<div class="grid">
<section class="card">
<h1 class="title">Playground</h1>
<p class="muted subtle-copy">Use a managed API key to test one message quickly.</p>
<form id="playgroundForm">
<div class="row">
<div><label>API Key</label><select name="api_key" id="apiKey">{{range .Keys}}<option value="{{.Key}}" {{if eq $.PlayAPIKey .Key}}selected{{end}}>{{if .Name}}{{.Name}}{{else}}(unnamed){{end}} / {{.Key}}</option>{{end}}</select></div>
<div><label>Model</label><select name="model" id="model">{{range .PlayModels}}<option value="{{.}}" {{if eq $.PlayModel .}}selected{{end}}>{{.}}</option>{{end}}</select></div>
</div>

<div id="playgroundMain" style="display:none">
<div class="stack">
<div class="section">
<div class="field-label">API Style</div>
<div class="radio-group">
<label><input type="radio" name="api_style" value="openai" {{if not .PlayUseAnthropic}}checked{{end}}> OpenAI</label>
<label><input type="radio" name="api_style" value="anthropic" {{if .PlayUseAnthropic}}checked{{end}}> Anthropic</label>
</div>
</div>

<div id="openaiSub" class="section" style="{{if .PlayUseAnthropic}}display:none{{end}}">
<div class="field-label">OpenAI Endpoint</div>
<div class="radio-group">
<label><input type="radio" name="api_type" value="chat_completions" {{if not .PlayUseResponses}}checked{{end}}> Chat Completions</label>
<label><input type="radio" name="api_type" value="responses" {{if .PlayUseResponses}}checked{{end}}> Responses</label>
</div>
</div>

<div class="section">
<label style="display:flex;align-items:center;gap:8px"><input type="checkbox" name="stream" id="stream" {{if .PlayStream}}checked{{end}} style="width:auto"> Stream</label>
</div>

<div>
<label>Message</label>
<textarea name="message" id="message" placeholder="Say something...">{{.PlayMessage}}</textarea>
<div class="hint-row">
<span class="hint">Best for quick validation of key, model and endpoint behavior.</span>
<span id="loadingHint" class="hint" style="display:none">Sending...</span>
</div>
</div>
<div class="actions"><button type="submit" id="sendBtn">Send</button><a class="hint" href="/admin/playground">Clear</a></div>
</div>
</div>
</form>
{{if .PlayError}}<div class="error">{{.PlayError}}</div>{{end}}
<div id="errorDiv" class="error" style="display:none"></div>
<div id="resultDiv" class="result" style="display:none"></div>
{{if .PlayResult}}<div class="result"><span class="result-title">Reply</span>{{.PlayResult}}</div>{{end}}
</section>
<aside class="card">
<h2 class="title">Connect Settings</h2>
<p class="muted subtle-copy" id="modeHint">OpenAI Chat Completions. Copy into your client app.</p>
<div id="connectKv" style="display:none" class="stack">
<div class="kv"><div class="muted">API Base URL</div><div class="mono" id="cfgBase">{{.PlayAPIBase}}/v1</div><button type="button" class="ghost" onclick="copyText('cfgBase', this)">Copy</button></div>
<div class="kv"><div class="muted">API Key</div><div class="mono" id="cfgKey">{{.PlayAPIKey}}</div><button type="button" class="ghost" onclick="copyText('cfgKey', this)">Copy</button></div>
<div class="kv"><div class="muted">Model</div><div class="mono" id="cfgModel">{{.PlayModel}}</div><button type="button" class="ghost" onclick="copyText('cfgModel', this)">Copy</button></div>
<div class="metric">
<div class="metric-label">Request Shape</div>
<div class="metric-value">Same auth, routing and upstream call path as the public API.</div>
</div>
</div>
<div class="hint" id="endpointHint">Use endpoint: <span class="mono">/chat/completions</span></div>
</aside>
</div>
</div>
<script>
async function copyText(id, button){
	const el = document.getElementById(id);
	if(!el){return;}
	try{
		await copyWithFallback(el.textContent || "");
		const origin = button.textContent;
		button.textContent = "Copied";
		setTimeout(()=>{button.textContent = origin;}, 1000);
	}catch(_e){
		button.textContent = "Failed";
		setTimeout(()=>{button.textContent = "Copy";}, 1000);
	}
}

async function copyWithFallback(value){
	if (navigator.clipboard && window.isSecureContext) {
		await navigator.clipboard.writeText(value);
		return;
	}
	const textArea = document.createElement("textarea");
	textArea.value = value;
	textArea.setAttribute("readonly", "");
	textArea.style.position = "fixed";
	textArea.style.left = "-9999px";
	document.body.appendChild(textArea);
	textArea.select();
	const ok = document.execCommand("copy");
	document.body.removeChild(textArea);
	if (!ok) {
		throw new Error("copy failed");
	}
}

const form = document.getElementById('playgroundForm');
const sendBtn = document.getElementById('sendBtn');
const loadingHint = document.getElementById('loadingHint');
const resultDiv = document.getElementById('resultDiv');
const errorDiv = document.getElementById('errorDiv');
const modeHint = document.getElementById('modeHint');
const cfgBase = document.getElementById('cfgBase');
const cfgKey = document.getElementById('cfgKey');
const cfgModel = document.getElementById('cfgModel');
const endpointHint = document.getElementById('endpointHint');
const openaiSub = document.getElementById('openaiSub');
const playgroundMain = document.getElementById('playgroundMain');
const connectKv = document.getElementById('connectKv');
const apiKeySelect = document.getElementById('apiKey');
const modelSelect = document.getElementById('model');
const apiBaseEl = document.getElementById('apiBaseData');
const apiBase = apiBaseEl ? apiBaseEl.textContent : '';

function getApiStyle(){ return document.querySelector('input[name="api_style"]:checked')?.value || 'openai'; }
function getApiType(){ return document.querySelector('input[name="api_type"]:checked')?.value || 'chat_completions'; }

function updateModeUI(){
	const style = getApiStyle();
	const apiType = getApiType();

	openaiSub.style.display = style === 'openai' ? '' : 'none';

	if (style === 'anthropic') {
		modeHint.textContent = 'Anthropic Messages API. Copy into your client app.';
		cfgBase.textContent = apiBase + '/anthropic';
		endpointHint.innerHTML = 'Use endpoint: <span class="mono">/messages</span>';
	} else if (apiType === 'responses') {
		modeHint.textContent = 'OpenAI Responses API. Copy into your client app.';
		cfgBase.textContent = apiBase + '/v1';
		endpointHint.innerHTML = 'Use endpoint: <span class="mono">/responses</span>';
	} else {
		modeHint.textContent = 'OpenAI Chat Completions. Copy into your client app.';
		cfgBase.textContent = apiBase + '/v1';
		endpointHint.innerHTML = 'Use endpoint: <span class="mono">/chat/completions</span>';
	}
}

document.querySelectorAll('input[name="api_style"]').forEach(r => r.addEventListener('change', updateModeUI));
document.querySelectorAll('input[name="api_type"]').forEach(r => r.addEventListener('change', updateModeUI));

function toggleMain(){
	const hasKey = apiKeySelect.value !== '';
	playgroundMain.style.display = hasKey ? '' : 'none';
	connectKv.style.display = hasKey ? '' : 'none';
}

function updateConnectionValues(){
	cfgKey.textContent = apiKeySelect.value;
	cfgModel.textContent = modelSelect.value;
}

apiKeySelect.addEventListener('change', () => {
	toggleMain();
	updateConnectionValues();
	updateModeUI();
});

modelSelect.addEventListener('change', updateConnectionValues);

form.addEventListener('submit', async (e) => {
	e.preventDefault();
	sendBtn.disabled = true;
	loadingHint.style.display = 'inline';
	resultDiv.style.display = 'none';
	errorDiv.style.display = 'none';

const params = new URLSearchParams();
	params.append('api_key', apiKeySelect.value);
	params.append('model', modelSelect.value);
	params.append('message', document.getElementById('message').value);
	params.append('api_style', getApiStyle());
	params.append('api_type', getApiType());
	if (document.getElementById('stream').checked) {
		params.append('stream', 'on');
	}

	try {
		const resp = await fetch('/admin/playground/chat/ajax', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/x-www-form-urlencoded',
			},
			body: params,
		});
		const data = await resp.json();
		if (!resp.ok) {
			throw new Error(data.error || 'Request failed');
		}
		resultDiv.textContent = data.result;
		resultDiv.insertAdjacentHTML('afterbegin', '<span class="result-title">Reply</span>');
		resultDiv.style.display = 'block';
	} catch (err) {
		errorDiv.textContent = err.message;
		errorDiv.style.display = 'block';
	} finally {
		sendBtn.disabled = false;
	loadingHint.style.display = 'none';
	}
});

toggleMain();
updateConnectionValues();
updateModeUI();
</script>
</body></html>
