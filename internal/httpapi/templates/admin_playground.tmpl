<!doctype html>
<html><head><meta charset="utf-8"><title>{{.Title}}</title>
<style>
:root{--bg:#16161a;--card:rgba(0,30,29,.45);--line:#72757e;--text:#fffffe;--muted:#94a1b2;--accent:#7f5af0}
*{box-sizing:border-box}
body{margin:0;background:#16161a;color:var(--text);font-family:-apple-system,BlinkMacSystemFont,sans-serif}
.wrap{max-width:1280px;margin:24px auto;padding:0 16px}
nav{display:flex;gap:14px;align-items:center;margin-bottom:18px}
nav a{text-decoration:none;color:#fffffe}
.logout{margin-left:auto}
button{border:0;background:#7f5af0;color:#fffffe;border-radius:10px;padding:9px 14px;cursor:pointer;font-weight:600}
button:disabled{opacity:0.5;cursor:not-allowed}
.ghost{background:#72757e;color:#fffffe}
.grid{display:grid;grid-template-columns:1.1fr .9fr;gap:16px}
.card{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px}
.title{font-size:20px;margin:0 0 8px}
.muted{color:var(--muted)}
.row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
select,input,textarea{width:100%;padding:10px;border:1px solid #72757e;border-radius:10px;background:#fffffe;color:#010101}
textarea{min-height:180px;resize:vertical}
.actions{display:flex;gap:10px;align-items:center}
.hint{font-size:12px;color:var(--muted)}
.result{margin-top:12px;border:1px solid var(--line);border-radius:10px;background:rgba(255,255,255,.02);padding:12px;white-space:pre-wrap;max-height:360px;overflow:auto}
.error{margin-top:10px;padding:10px;border-radius:10px;background:#fff2f2;color:#9f2d2d;border:1px solid #ffd1d1}
.kv{display:grid;grid-template-columns:120px 1fr auto;gap:8px;align-items:center;margin-bottom:8px}
.mono{font-family:ui-monospace,SFMono-Regular,monospace;font-size:13px;word-break:break-all}
.hidden{display:none}
.radio-group{display:flex;gap:16px;flex-wrap:wrap}
.radio-group label{display:flex;align-items:center;gap:6px;cursor:pointer;font-size:14px}
.radio-group input{width:auto}
.field-label{font-size:13px;color:var(--muted);margin-bottom:6px}
@media (max-width:900px){.grid{grid-template-columns:1fr}.row{grid-template-columns:1fr}}
</style>
</head><body><div class="wrap">
{{template "admin_nav" .}}
<div id="apiBaseData" class="hidden">{{.PlayAPIBase}}</div>
<div class="grid">
<section class="card">
<h1 class="title">Playground</h1>
<p class="muted">Use a managed API key to test one message quickly.</p>
<form id="playgroundForm">
<div class="row">
<div><label>API Key</label><select name="api_key" id="apiKey">{{range .Keys}}<option value="{{.Key}}" {{if eq $.PlayAPIKey .Key}}selected{{end}}>{{if .Name}}{{.Name}}{{else}}(unnamed){{end}} / {{.Key}}</option>{{end}}</select></div>
<div><label>Model</label><select name="model" id="model">{{range .PlayModels}}<option value="{{.}}" {{if eq $.PlayModel .}}selected{{end}}>{{.}}</option>{{end}}</select></div>
</div>

<div style="margin-bottom:10px">
<div class="field-label">API Style</div>
<div class="radio-group">
<label><input type="radio" name="api_style" value="openai" {{if not .PlayUseAnthropic}}checked{{end}}> OpenAI</label>
<label><input type="radio" name="api_style" value="anthropic" {{if .PlayUseAnthropic}}checked{{end}}> Anthropic</label>
</div>
</div>

<div id="openaiSub" style="margin-bottom:10px{{if .PlayUseAnthropic}};display:none{{end}}">
<div class="field-label">OpenAI Endpoint</div>
<div class="radio-group">
<label><input type="radio" name="api_type" value="chat_completions" {{if not .PlayUseResponses}}checked{{end}}> Chat Completions</label>
<label><input type="radio" name="api_type" value="responses" {{if .PlayUseResponses}}checked{{end}}> Responses</label>
</div>
</div>

<div style="margin-bottom:10px">
<label style="display:flex;align-items:center;gap:8px"><input type="checkbox" name="stream" id="stream" {{if .PlayStream}}checked{{end}} style="width:auto"> Stream</label>
</div>

<div style="margin-bottom:10px"><label>Message</label><textarea name="message" id="message" placeholder="Say something...">{{.PlayMessage}}</textarea></div>
<div class="actions"><button type="submit" id="sendBtn">Send</button><a class="hint" href="/admin/playground">Clear</a><span id="loadingHint" class="hint" style="display:none">Sending...</span></div>
</form>
{{if .PlayError}}<div class="error">{{.PlayError}}</div>{{end}}
<div id="errorDiv" class="error" style="display:none"></div>
<div id="resultDiv" class="result" style="display:none"></div>
{{if .PlayResult}}<div class="result">{{.PlayResult}}</div>{{end}}
</section>
<aside class="card">
<h2 class="title">Connect Settings</h2>
<p class="muted" id="modeHint">OpenAI Chat Completions. Copy into your client app.</p>
<div class="kv"><div class="muted">API Base URL</div><div class="mono" id="cfgBase">{{.PlayAPIBase}}/v1</div><button type="button" class="ghost" onclick="copyText('cfgBase', this)">Copy</button></div>
<div class="kv"><div class="muted">API Key</div><div class="mono" id="cfgKey">{{.PlayAPIKey}}</div><button type="button" class="ghost" onclick="copyText('cfgKey', this)">Copy</button></div>
<div class="kv"><div class="muted">Model</div><div class="mono" id="cfgModel">{{.PlayModel}}</div><button type="button" class="ghost" onclick="copyText('cfgModel', this)">Copy</button></div>
<div class="hint" id="endpointHint">Use endpoint: <span class="mono">/chat/completions</span></div>
</aside>
</div>
</div>
<script>
async function copyText(id, button){
	const el = document.getElementById(id);
	if(!el){return;}
	try{
		await copyWithFallback(el.textContent || "");
		const origin = button.textContent;
		button.textContent = "Copied";
		setTimeout(()=>{button.textContent = origin;}, 1000);
	}catch(_e){
		button.textContent = "Failed";
		setTimeout(()=>{button.textContent = "Copy";}, 1000);
	}
}

async function copyWithFallback(value){
	if (navigator.clipboard && window.isSecureContext) {
		await navigator.clipboard.writeText(value);
		return;
	}
	const textArea = document.createElement("textarea");
	textArea.value = value;
	textArea.setAttribute("readonly", "");
	textArea.style.position = "fixed";
	textArea.style.left = "-9999px";
	document.body.appendChild(textArea);
	textArea.select();
	const ok = document.execCommand("copy");
	document.body.removeChild(textArea);
	if (!ok) {
		throw new Error("copy failed");
	}
}

const form = document.getElementById('playgroundForm');
const sendBtn = document.getElementById('sendBtn');
const loadingHint = document.getElementById('loadingHint');
const resultDiv = document.getElementById('resultDiv');
const errorDiv = document.getElementById('errorDiv');
const modeHint = document.getElementById('modeHint');
const cfgBase = document.getElementById('cfgBase');
const endpointHint = document.getElementById('endpointHint');
const openaiSub = document.getElementById('openaiSub');
const apiBaseEl = document.getElementById('apiBaseData');
const apiBase = apiBaseEl ? apiBaseEl.textContent : '';

function getApiStyle(){ return document.querySelector('input[name="api_style"]:checked')?.value || 'openai'; }
function getApiType(){ return document.querySelector('input[name="api_type"]:checked')?.value || 'chat_completions'; }

function updateModeUI(){
	const style = getApiStyle();
	const apiType = getApiType();

	openaiSub.style.display = style === 'openai' ? '' : 'none';

	if (style === 'anthropic') {
		modeHint.textContent = 'Anthropic Messages API. Copy into your client app.';
		cfgBase.textContent = apiBase + '/anthropic';
		endpointHint.innerHTML = 'Use endpoint: <span class="mono">/messages</span>';
	} else if (apiType === 'responses') {
		modeHint.textContent = 'OpenAI Responses API. Copy into your client app.';
		cfgBase.textContent = apiBase + '/v1';
		endpointHint.innerHTML = 'Use endpoint: <span class="mono">/responses</span>';
	} else {
		modeHint.textContent = 'OpenAI Chat Completions. Copy into your client app.';
		cfgBase.textContent = apiBase + '/v1';
		endpointHint.innerHTML = 'Use endpoint: <span class="mono">/chat/completions</span>';
	}
}

document.querySelectorAll('input[name="api_style"]').forEach(r => r.addEventListener('change', updateModeUI));
document.querySelectorAll('input[name="api_type"]').forEach(r => r.addEventListener('change', updateModeUI));

form.addEventListener('submit', async (e) => {
	e.preventDefault();
	sendBtn.disabled = true;
	loadingHint.style.display = 'inline';
	resultDiv.style.display = 'none';
	errorDiv.style.display = 'none';

	const params = new URLSearchParams();
	params.append('api_key', document.getElementById('apiKey').value);
	params.append('model', document.getElementById('model').value);
	params.append('message', document.getElementById('message').value);
	params.append('api_style', getApiStyle());
	params.append('api_type', getApiType());
	if (document.getElementById('stream').checked) {
		params.append('stream', 'on');
	}

	try {
		const resp = await fetch('/admin/playground/chat/ajax', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/x-www-form-urlencoded',
			},
			body: params,
		});
		const data = await resp.json();
		if (!resp.ok) {
			throw new Error(data.error || 'Request failed');
		}
		resultDiv.textContent = data.result;
		resultDiv.style.display = 'block';
	} catch (err) {
		errorDiv.textContent = err.message;
		errorDiv.style.display = 'block';
	} finally {
		sendBtn.disabled = false;
		loadingHint.style.display = 'none';
	}
});
</script>
</body></html>
