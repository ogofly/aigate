<!doctype html>
<html lang="{{.Lang}}">
<head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{.Title}}</title>{{template "admin_head_assets" .}}
{{template "admin_theme_init" .}}
<style>{{template "admin_common_styles" .}}body{margin:0;padding:0 16px;min-height:100vh;display:flex;align-items:center;justify-content:center}.login-shell{width:min(100%,460px)}.login-card{background:linear-gradient(180deg, rgba(210,214,220,.04), rgba(210,214,220,.024));border:1px solid var(--line);border-radius:6px;padding:24px;box-shadow:var(--shadow)}.login-brand{display:flex;align-items:center;gap:12px;margin-bottom:14px}.login-logo{width:52px;height:52px}.login-brand h1{margin:0}.login-copy{margin-bottom:16px}.login-form{display:flex;flex-direction:column;gap:12px}.login-form button{padding:12px 16px;font-size:15px}.error{padding:10px 12px;border:1px solid rgba(180,80,80,.22);border-radius:8px;background:rgba(120,42,42,.1);color:#d2a0a0;margin-bottom:12px}@media (max-width:520px){.login-card{padding:18px}}</style>
</head><body><div class="login-shell"><div class="login-card panel" style="position:relative"><div class="login-brand"><img class="login-logo" src="/assets/logo.svg" alt="" width="52" height="52"><div><h1>LLM Gateway</h1></div></div>{{template "admin_theme_button_login" .}}<div class="muted login-copy">{{.T "Sign in with an admin account, or use a user name with a managed API key."}}</div>{{if .Error}}<div class="error">{{.T .Error}}</div>{{end}}<form method="post" action="/admin/login" class="login-form"><input name="username" placeholder="{{.T "Username"}}" autocomplete="username" autofocus required><input type="password" name="password" placeholder="{{.T "Password or API key"}}" autocomplete="current-password" required><button type="submit">{{.T "Sign In"}}</button></form></div></div>{{template "admin_theme_toggle" .}}</body></html>
