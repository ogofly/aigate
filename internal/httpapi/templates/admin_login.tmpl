<!doctype html>
<html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{.Title}}</title>
<style>{{template "admin_common_styles" .}}body{display:flex;align-items:center;justify-content:center;min-height:100vh}.login-shell{width:min(100%,460px)}.login-card{background:var(--card);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:24px}.login-copy{margin-bottom:16px}.login-form{display:flex;flex-direction:column;gap:12px}.error{color:#ffddd2;margin-bottom:12px}@media (max-width:520px){.login-card{padding:18px}}</style>
</head><body><div class="login-shell"><div class="login-card"><h1>Web Login</h1><div class="muted login-copy">Admin: username/password. User: username(owner) + api key.</div>{{if .Error}}<div class="error">{{.Error}}</div>{{end}}<form method="post" action="/admin/login" class="login-form"><input name="username" placeholder="username"><input type="password" name="password" placeholder="password or api key"><button type="submit">Sign In</button></form></div></div></body></html>
