<!doctype html>
<html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{.Title}}</title>
<style>{{template "admin_common_styles" .}}body{display:flex;align-items:center;justify-content:center;min-height:100vh}.login-shell{width:min(100%,460px)}.login-card{background:var(--card);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:24px}.login-kicker{margin:0 0 8px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}.login-copy{margin-bottom:16px}.login-form{display:flex;flex-direction:column;gap:12px}.error{color:#ffddd2;margin-bottom:12px}@media (max-width:520px){.login-card{padding:18px}}</style>
</head><body><div class="login-shell"><div class="login-card"><div class="login-kicker">Gateway Console</div><h1>LLM Gateway</h1><div class="muted login-copy">Sign in with an admin account, or use an owner name with a managed API key.</div>{{if .Error}}<div class="error">{{.Error}}</div>{{end}}<form method="post" action="/admin/login" class="login-form"><input name="username" placeholder="Username"><input type="password" name="password" placeholder="Password or API key"><button type="submit">Sign In</button></form></div></div></body></html>
